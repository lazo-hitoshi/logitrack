    function applyEditabilityForBatch(batch) {
        if (!batch) return;
        // 配車モード（ダンプ登録（配車））は “編集:ON” とは別物なので、
        // manualEditEnabled によるロックを適用しない（ロット番号選択ができなくなるため）
        if (ENABLE_DISPATCH_OVERRIDES && isDispatchMode()) {
            const parentShipSelect = document.getElementById('parent-ship-select');
            if (parentShipSelect) parentShipSelect.disabled = false;
            const siteEl = document.getElementById('lot-site');
            if (siteEl) siteEl.disabled = false;
            const portEntryEl = document.getElementById('port-entry-date');
            if (portEntryEl) portEntryEl.readOnly = false;
            const dispatchDateEl = document.getElementById('dispatch-date');
            if (dispatchDateEl) dispatchDateEl.readOnly = false;
            const notesEl = document.getElementById('lot-notes');
            if (notesEl) notesEl.readOnly = false;
            return;
        }
        // “閲覧専用”が基本。編集ON時のみ、許可した項目だけ触れる
        const enable = !!manualEditEnabled;
        const allow = (id, mode = 'readonly') => {
            const el = document.getElementById(id);
            if (!el) return;
            if (mode === 'disabled') {
                el.disabled = !enable;
            } else {
                el.readOnly = !enable;
            }
            el.style.backgroundColor = enable ? 'rgba(59, 130, 246, 0.10)' : '';
        };

        if (batch.type === 'sea') {
            allow('lot-location', 'disabled');
            allow('lot-site', 'disabled');
            allow('lot-plant', 'readonly');
            allow('departure-date', 'readonly');
            allow('lot-notes', 'readonly');
        } else {
            // ダンプは配車関連だけ許可（車両情報は誤変更防止で固定）
            allow('parent-ship-select', 'disabled');
            allow('lot-site', 'disabled');
            allow('port-entry-date', 'readonly');
            allow('dispatch-date', 'readonly');
            allow('lot-notes', 'readonly');
        }
    }

