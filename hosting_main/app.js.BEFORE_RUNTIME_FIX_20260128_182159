    // --- Map Drawing Logic (2 Maps for 2 Ships) ---
    const canvases = [];
    const contexts = [];

    // マップ初期化関数
    function initMaps() {
        const containers = [
            document.getElementById('map-canvas-1'),
            document.getElementById('map-canvas-2')
        ];
        
        console.log('initMaps開始:', {
            container1: containers[0] ? '存在' : '存在しない',
            container2: containers[1] ? '存在' : '存在しない',
            container1Size: containers[0] ? `${containers[0].clientWidth}x${containers[0].clientHeight}` : 'なし',
            container2Size: containers[1] ? `${containers[1].clientWidth}x${containers[1].clientHeight}` : 'なし'
        });
        
        containers.forEach((container, index) => {
            if (container) {
                // 既存のcanvasを削除
                const existingCanvas = container.querySelector('canvas');
                if (existingCanvas) {
                    existingCanvas.remove();
                }
                
                const canvas = document.createElement('canvas');
                const ctx = canvas.getContext('2d');
                if (!ctx) {
                    console.error(`マップ${index + 1}のcanvas contextが取得できません`);
                    return;
                }
                
                // canvasのスタイルを設定
                canvas.style.width = '100%';
                canvas.style.height = '100%';
                canvas.style.display = 'block';
                container.appendChild(canvas);
                canvases[index] = canvas;
                contexts[index] = ctx;
                
                // サイズを即座に設定（デフォルト値を使用）
                const width = container.clientWidth || 400;
                const height = container.clientHeight || 450;
                canvas.width = width;
                canvas.height = height;
                console.log(`マップ${index + 1}のcanvasを作成しました: ${width}x${height}`);
            } else {
                console.warn(`マップ${index + 1}のコンテナが見つかりません`);
            }
        });
        
        // マップ描画を開始
        if (canvases.filter(c => c).length > 0) {
            // 少し遅延させてから描画（DOM更新を確実にするため）
            setTimeout(() => {
                // 再度サイズを確認して設定
                canvases.forEach((canvas, idx) => {
                    if (canvas) {
                        const container = document.getElementById(`map-canvas-${idx + 1}`);
                        if (container) {
                            const width = container.clientWidth || 400;
                            const height = container.clientHeight || 450;
                            if (canvas.width !== width || canvas.height !== height) {
                                canvas.width = width;
                                canvas.height = height;
                                console.log(`マップ${idx + 1}のサイズを更新: ${width}x${height}`);
                            }
                        }
                    }
                });
                drawMap();
            }, 100);
        } else {
            console.warn('canvasが作成されていません');
        }
    }
    
    // 初期化を実行（DOMが読み込まれた後に実行）
    function tryInitMaps() {
        const containers = [
            document.getElementById('map-canvas-1'),
            document.getElementById('map-canvas-2')
        ];
        if (containers[0] && containers[1]) {
            initMaps();
            return true;
        }
        return false;
    }
    
    // 即座に試行
    if (!tryInitMaps()) {
        // DOMがまだ読み込まれていない場合は、遅延実行
        setTimeout(() => {
            if (!tryInitMaps()) {
                // さらに遅延して再試行
                setTimeout(() => {
