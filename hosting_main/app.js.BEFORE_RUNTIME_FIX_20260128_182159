    function applyShipInfoToLot(ship, rootEl = null) {
        if (!ship) return;
        // モーダル差し替え等でIDが重複するケースがあるため、可能なら「現在のモーダル内」を優先して取得する
        const getEl = (id) => (rootEl && rootEl.querySelector ? rootEl.querySelector(`#${id}`) : null) || document.getElementById(id);
        const siteEl = getEl('lot-site');
        const plantEl = getEl('lot-plant');
        const soilTypeEl = getEl('soil-type');
        const locationEl = getEl('lot-location');
        const grossTonnageEl = getEl('lot-gross-tonnage');
        const weightTonnageEl = getEl('lot-weight-tonnage');
        const volumeEl = getEl('lot-volume');

        if (siteEl && ship.site) siteEl.value = ship.site;
        if (plantEl && ship.plant) plantEl.value = ship.plant;
        if (soilTypeEl && ship.soilType) soilTypeEl.value = ship.soilType;
        if (locationEl && ship.location) locationEl.value = ship.location;
        // 数値0など falsy な値でも確実に反映させる
        const hasVal = (v) => v !== undefined && v !== null && String(v) !== '';
        if (grossTonnageEl && hasVal(ship.grossTonnage)) grossTonnageEl.value = String(ship.grossTonnage);
        if (weightTonnageEl && hasVal(ship.weightTonnage)) weightTonnageEl.value = String(ship.weightTonnage);
        if (volumeEl && hasVal(ship.volume)) volumeEl.value = String(ship.volume);
    }

