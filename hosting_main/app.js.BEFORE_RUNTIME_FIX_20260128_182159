            if (typeof firebase === 'undefined') {
                console.warn('[Firestore] firebase SDK が読み込まれていません。index.html の script を確認してください。');
                return false;
            }
            const cfg = window.firebaseConfig;
            if (!cfg || !cfg.projectId || !cfg.apiKey || cfg.apiKey === 'YOUR_API_KEY') {
                console.warn('[Firestore] firebaseConfig が未設定です。index.html の window.firebaseConfig を設定してください。');
                return false;
            }
            if (!firebase.apps.length) {
                firebase.initializeApp(cfg);
            }
            firestoreDb = firebase.firestore();
            firestoreEnabled = true;
            console.log('[Firestore] initialized:', cfg.projectId);
            return true;
        } catch (e) {
            console.error('[Firestore] init error:', e);
            return false;
        }
    }

    async function firestoreUpsertLot(batch) {
        if (!firestoreEnabled || !firestoreDb || !batch?.id) return;
        const payload = { ...batch, updatedAt: new Date().toISOString() };
        await firestoreDb.collection(FIRESTORE_COLLECTION_LOTS).doc(batch.id).set(payload, { merge: true });
    }

    async function firestoreDeleteLot(lotId) {
        if (!firestoreEnabled || !firestoreDb || !lotId) return;
        await firestoreDb.collection(FIRESTORE_COLLECTION_LOTS).doc(lotId).delete();
    }

    async function firestoreUpsertHistory(item) {
        if (!firestoreEnabled || !firestoreDb || !item?.id) return;
        const payload = { ...item, updatedAt: new Date().toISOString() };
        await firestoreDb.collection(FIRESTORE_COLLECTION_HISTORY).doc(item.id).set(payload, { merge: true });
    }

    let mastersSaveTimer = null;
    function firestoreUpsertMastersDebounced() {
        if (!firestoreEnabled || !firestoreDb) return;
        if (mastersSaveTimer) clearTimeout(mastersSaveTimer);
        mastersSaveTimer = setTimeout(() => {
            firestoreUpsertMasters().catch(() => {});
        }, 400);
    }

    async function firestoreUpsertMasters() {
        if (!firestoreEnabled || !firestoreDb) return;
        const payload = {
            ...state.masters,
            updatedAt: new Date().toISOString()
        };
        await firestoreDb.collection(FIRESTORE_COLLECTION_META).doc(FIRESTORE_DOC_MASTERS).set(payload, { merge: true });
    }

    async function firestoreLoadMasters() {
        if (!firestoreEnabled || !firestoreDb) return null;
        const snap = await firestoreDb.collection(FIRESTORE_COLLECTION_META).doc(FIRESTORE_DOC_MASTERS).get();
        if (!snap.exists) return null;
        return snap.data() || null;
    }

    async function ensureFirestoreLoadedOnce() {
        if (!firestoreEnabled || !firestoreDb) return false;
        if (firestoreLoadPromise) return firestoreLoadPromise;

        firestoreLoadPromise = (async () => {
            try {
                const localLots = Array.isArray(state.batches) ? [...state.batches] : [];
                const localHist = Array.isArray(state.history) ? [...state.history] : [];

                // 取り込み前にローカルをバックアップ（Firestore導入直後の“消えた”を防ぐ）
                try {
                    const ts = new Date().toISOString().replace(/[:.]/g, '-');
                    localStorage.setItem(`dump_truck_system_state_backup_${ts}`, JSON.stringify({ ...state }));
                } catch (_) {
                    // ignore
                }

                // masters をFirestoreから復元（端末間で共通化）
                try {
                    const remoteMasters = await firestoreLoadMasters();
                    if (remoteMasters) {
                        const mergeStringArray = (a, b) => Array.from(new Set([...(a || []), ...(b || [])].filter(Boolean)));
                        const merged = { ...(state.masters || {}) };
                        merged.companies = mergeStringArray(merged.companies, remoteMasters.companies);
                        merged.vessels = mergeStringArray(merged.vessels, remoteMasters.vessels);
                        merged.ports = mergeStringArray(merged.ports, remoteMasters.ports);
                        merged.sites = mergeStringArray(merged.sites, remoteMasters.sites);
                        merged.truckCategories = mergeStringArray(merged.truckCategories, remoteMasters.truckCategories);

                        // trucks: name でマージ（remote優先）
                        const truckMap = new Map();
                        (merged.trucks || []).forEach(t => { if (t?.name) truckMap.set(t.name, t); });
                        (remoteMasters.trucks || []).forEach(t => { if (t?.name) truckMap.set(t.name, t); });
                        merged.trucks = Array.from(truckMap.values());

                        // shipPresets: idでマージ（remote優先）
                        const presetMap = new Map();
                        (merged.shipPresets || []).forEach(p => { if (p?.id) presetMap.set(p.id, p); });
                        (remoteMasters.shipPresets || []).forEach(p => { if (p?.id) presetMap.set(p.id, p); });
                        merged.shipPresets = Array.from(presetMap.values());

                        state.masters = merged;
                    }
                } catch (_) {
                    // ignore
                }

                const mergeById = (localArr, remoteArr) => {
                    const map = new Map();
                    localArr.forEach(item => {
                        if (item && item.id) map.set(item.id, item);
                    });
                    remoteArr.forEach(item => {
                        if (item && item.id) map.set(item.id, item);
                    });
                    return Array.from(map.values());
                };

                const lotsSnap = await firestoreDb.collection(FIRESTORE_COLLECTION_LOTS).get();
                const remoteLots = [];
                lotsSnap.forEach(doc => {
                    const data = doc.data() || {};
                    if (!data.id) data.id = doc.id;
                    remoteLots.push(data);
                });

                const histSnap = await firestoreDb.collection(FIRESTORE_COLLECTION_HISTORY).get();
                const remoteHist = [];
                histSnap.forEach(doc => {
                    const data = doc.data() || {};
                    if (!data.id) data.id = doc.id;
                    remoteHist.push(data);
                });

                // Firestoreが空でもローカルは保持し、Firestoreがあってもローカルを捨てずにマージする
                if (remoteLots.length) {
                    state.batches = mergeById(localLots, remoteLots);
                } else {
                    state.batches = localLots;
                }

                if (remoteHist.length) {
                    state.history = mergeById(localHist, remoteHist);
                } else {
                    state.history = localHist;
                }

                // Firestoreが空 or 不足している場合、ローカルで持っている分をFirestoreへ同期（初回の“空で消える”を防ぐ）
                try {
                    const remoteLotIds = new Set(remoteLots.filter(x => x && x.id).map(x => x.id));
                    const remoteHistIds = new Set(remoteHist.filter(x => x && x.id).map(x => x.id));

                    const lotsToUpsert = localLots.filter(x => x && x.id && !remoteLotIds.has(x.id));
                    const histToUpsert = localHist.filter(x => x && x.id && !remoteHistIds.has(x.id));

                    if (lotsToUpsert.length || histToUpsert.length) {
                        console.log('[Firestore] seeding from local:', { lots: lotsToUpsert.length, history: histToUpsert.length });
                    }
                    await Promise.all([
                        ...lotsToUpsert.map(b => firestoreUpsertLot(b).catch(() => {})),
                        ...histToUpsert.map(h => firestoreUpsertHistory(h).catch(() => {}))
                    ]);
                } catch (e) {
                    console.warn('[Firestore] seed warn:', e);
                }

                // Legacy補完
                if (!state.history) state.history = [];
                state.batches.forEach(b => {
                    if (b.type === 'sea' && !b.arrivalDate) {
                        b.arrivalDate = new Date().toISOString().split('T')[0];
                    }
                });

                window.state = state;
                normalizeMasterLists();
                normalizeEntryBatches();
                saveState(); // ローカルにも反映（オフラインでも表示できる）
                console.log('[Firestore] loaded into state:', {
                    localLots: localLots.length,
                    remoteLots: remoteLots.length,
                    mergedLots: state.batches.length,
                    localHistory: localHist.length,
                    remoteHistory: remoteHist.length,
                    mergedHistory: state.history.length
                });

                // masters がFirestoreに無い/不足なら、ローカルのmastersを同期
                firestoreUpsertMastersDebounced();
                return true;
            } catch (e) {
                console.error('[Firestore] load error:', e);
                return false;
            }
        })();

        return firestoreLoadPromise;
    }

    // Firestore初期化（設定が入っていれば有効化）
    initFirestore();

    function saveState() {
        localStorage.setItem('dump_truck_system_state', JSON.stringify(state));
