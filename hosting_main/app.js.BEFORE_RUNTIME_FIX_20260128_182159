    // --- AppSheet API Helper ---
    async function appSheetRequest(tableName, action, properties = {}, rows = []) {
        if (!APPSHEET_CONFIG.appId || !APPSHEET_CONFIG.accessKey || APPSHEET_CONFIG.appId.includes('YOUR_APP_ID')) {
            console.warn('AppSheet Config is missing. Skipping API request.');
            return null;
        }

        const url = `https://api.appsheet.com/api/v2/apps/${APPSHEET_CONFIG.appId}/tables/${tableName}/Action`;
        const body = {
            "Action": action,
            "Properties": {
                "Locale": "ja-JP",
                "Timezone": "Tokyo Standard Time",
                ...properties
            },
            "Rows": rows
        };

        try {
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'ApplicationAccessKey': APPSHEET_CONFIG.accessKey,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(body)
            });
            if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
            return await response.json();
        } catch (error) {
            console.error('AppSheet API Error:', error);
            // ユーザーへの通知（トーストなど）を行っても良い
            alert(`AppSheetへの送信に失敗しました（設定を確認してください）: ${error.message}`);
            return null;
        }
    }

