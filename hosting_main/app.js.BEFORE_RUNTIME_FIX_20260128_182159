    // showDebugInfoはグローバルスコープで既に定義されているため、ここでは定義しない
    
    // 入場登録済み（配車待ち）のダンプを日付別に表示
    function renderEntryRegistered() {
        try {
            // stateを確実に取得（window.stateからも取得を試みる）
            const currentState = state || window.state;
            if (!currentState || !currentState.batches) {
                showDebugInfo('⚠️ stateが取得できません。再試行します。');
                setTimeout(() => {
                    renderEntryRegistered();
                }, 100);
                return;
            }
            
            showDebugInfo('renderEntryRegistered 開始');
            showDebugInfo(`全バッチ数: ${currentState.batches.length}`);
            
            // ダッシュボードのリスト要素を取得
            const dashboardList = document.getElementById('entry-registered-list-dashboard');
            showDebugInfo(`dashboardList: ${dashboardList ? '存在' : '存在しない'}`);
            
            const allLists = dashboardList ? [dashboardList] : [];
            
            if (allLists.length === 0) {
                showDebugInfo('⚠️ リスト要素が見つかりません。100ms後に再試行します。');
                // 要素が見つからない場合は、少し待ってから再試行
                setTimeout(() => {
                    renderEntryRegistered();
