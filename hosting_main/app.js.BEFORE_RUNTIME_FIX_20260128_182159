    function ensureSelectHasOption(selectEl, value) {
        if (!selectEl || !value) return;
        const exists = Array.from(selectEl.options).some(o => o.value === value);
        if (!exists) {
            selectEl.add(new Option(value, value));
        }
        selectEl.value = value;
    }

    function normalizeTruckCategory(value) {
        const v = String(value || '').trim();
        if (!v) return '';
        const list = Array.isArray(state?.masters?.truckCategories) ? state.masters.truckCategories : [];
        if (list.includes(v)) return v;
        if (v.includes('トレーラー') || v.toLowerCase().includes('trailer')) return 'トレーラー';
        // それ以外（10t/7t/5t/大型/中型/小型/その他など）は大型ダンプに寄せる（必要なら＋で追加可能）
        return '大型ダンプ';
    }

    function applyTruckMasterSelectionByName(name) {
        const n = String(name || '').trim();
        if (!n) return;
        const tr = (state?.masters?.trucks || []).find(t => t && t.name === n);
        if (!tr) return;

        const nameInput = document.getElementById('truck-name');
        if (nameInput) nameInput.value = tr.name || '';
        const cap = document.getElementById('truck-capacity');
        if (cap) cap.value = tr.capacity || '';
        const driver = document.getElementById('truck-driver');
        if (driver) driver.value = tr.driver || '';
        const comp = document.getElementById('truck-company-select');
        if (comp) ensureSelectHasOption(comp, tr.company || '');
        const cat = document.getElementById('truck-category');
        if (cat) ensureSelectHasOption(cat, normalizeTruckCategory(tr.category || ''));

        const idEl = document.getElementById('truck-id');
        if (idEl && tr.id) idEl.value = tr.id;

        const addrEl = document.getElementById('truck-company-address');
        if (addrEl && tr.companyAddress) addrEl.value = tr.companyAddress;
        const phoneEl = document.getElementById('truck-company-phone');
        if (phoneEl && tr.companyPhone) phoneEl.value = tr.companyPhone;
        const mobileEl = document.getElementById('truck-company-mobile');
        if (mobileEl && tr.companyMobile) mobileEl.value = tr.companyMobile;
    }

