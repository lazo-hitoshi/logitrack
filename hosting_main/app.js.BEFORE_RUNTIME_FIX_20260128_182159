                return;
            }
            
            // フィルタ条件: entry_registeredステータスのみを表示
            // （standbyや積込待ちはダンプ位置画面に表示されるため除外）
            const entryRegistered = currentState.batches.filter(b => {
            try {
                // 陸上バッチであること（typeが'land'または未定義）
                if (b.type && b.type !== 'land') {
                    return false;
                }
                
                // 完了していないこと
                if (b.status === '完了') {
                    return false;
                }
                
                // ステータスが entry_registered のみを表示
                // （standby、積込待ち、輸送中などは他の画面で表示されるため除外）
                if (b.status === 'entry_registered') {
                    showDebugInfo(`✅ フィルタ通過（ステータス）: ${b.name} (${b.status})`);
                    return true;
                }
                
                return false;
            } catch (e) {
                console.error('フィルタ処理エラー:', e, b);
                return false;
            }
        });
        
        showDebugInfo(`フィルタ後のバッチ数: ${entryRegistered.length}`);
        if (entryRegistered.length > 0) {
            showDebugInfo(`✅ フィルタ後のバッチ一覧:`);
            entryRegistered.forEach((b, idx) => {
                showDebugInfo(`  [${idx + 1}] ${b.name} (ID: ${b.id}) - status=${b.status}, type=${b.type}, notes=${b.notes || 'なし'}, portEntryDate=${b.portEntryDate || 'なし'}, createdAt=${b.createdAt ? b.createdAt.split('T')[0] : 'なし'}`);
            });
        } else {
            showDebugInfo('⚠️ フィルタ後のバッチが0件です。');
            // 全バッチの情報を表示（デバッグ用）
            const landBatches = currentState.batches.filter(b => b.type === 'land' || !b.type);
            showDebugInfo(`全バッチ（land）数: ${landBatches.length}`);
            landBatches.forEach((b, idx) => {
                if (idx < 10) { // 最初の10件だけ表示
                    showDebugInfo(`  全バッチ${idx + 1}: ${b.name} (ID: ${b.id}) - status=${b.status}, type=${b.type}, notes=${b.notes || 'なし'}, portEntryDate=${b.portEntryDate || 'なし'}, createdAt=${b.createdAt ? b.createdAt.split('T')[0] : 'なし'}`);
                }
            });
        }
        
        // すべてのリスト要素に同じ内容を表示
        const emptyMessage = '<div style="text-align: center; padding: 20px; color: var(--text-muted);">入場登録済みのダンプはありません</div>';
        
        if (entryRegistered.length === 0) {
            showDebugInfo('⚠️ 表示するバッチがありません。空メッセージを表示します。');
            allLists.forEach(list => {
                if (list) list.innerHTML = emptyMessage;
            });
            return;
        }
        
        showDebugInfo(`HTMLを生成します。バッチ数: ${entryRegistered.length}`);
        
        // 日付別にグループ化
        showDebugInfo('日付別にグループ化を開始します');
        const groupedByDate = {};
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        
        entryRegistered.forEach(batch => {
            // portEntryDateが未設定の場合は、登録日時または今日の日付を使用
            let entryDate = batch.portEntryDate || '';
            if (!entryDate) {
                // 登録日時がある場合はそれを使用、なければ今日の日付を使用
                if (batch.createdAt) {
                    entryDate = batch.createdAt.split('T')[0]; // ISO形式から日付部分のみ取得
                } else {
                    // 今日の日付を使用
                    const today = new Date();
                    entryDate = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
                }
            }
            
            if (!entryDate) {
                // それでも日付が未設定の場合は「未設定」として扱う
                if (!groupedByDate['未設定']) groupedByDate['未設定'] = [];
                groupedByDate['未設定'].push(batch);
                return;
            }
            
            const date = new Date(entryDate);
            date.setHours(0, 0, 0, 0);
            const diffDays = Math.floor((date - today) / (1000 * 60 * 60 * 24));
            
            let dateLabel = '';
            if (diffDays === 0) {
                dateLabel = '今日';
            } else if (diffDays === 1) {
                dateLabel = '明日';
            } else if (diffDays === -1) {
                dateLabel = '昨日';
            } else if (diffDays > 0 && diffDays <= 7) {
                dateLabel = `${diffDays}日後`;
            } else if (diffDays < 0 && diffDays >= -7) {
                dateLabel = `${Math.abs(diffDays)}日前`;
            } else {
                // 日付をフォーマット（例：2026/01/16）
                dateLabel = `${date.getFullYear()}/${String(date.getMonth() + 1).padStart(2, '0')}/${String(date.getDate()).padStart(2, '0')}`;
            }
            
            const sortKey = entryDate; // ソート用のキー
            if (!groupedByDate[dateLabel]) {
                groupedByDate[dateLabel] = { items: [], sortKey: sortKey };
            }
            groupedByDate[dateLabel].items.push(batch);
        });
        
        // 日付順にソート（未設定は最後）
        const sortedDates = Object.keys(groupedByDate).sort((a, b) => {
            if (a === '未設定') return 1;
            if (b === '未設定') return -1;
            if (groupedByDate[a].sortKey && groupedByDate[b].sortKey) {
                return groupedByDate[a].sortKey.localeCompare(groupedByDate[b].sortKey);
            }
            return a.localeCompare(b);
        });
        
        // HTMLを生成
        showDebugInfo(`日付グループ数: ${sortedDates.length}, グループ: ${sortedDates.join(', ')}`);
        let html = '';
        sortedDates.forEach(dateLabel => {
            const group = groupedByDate[dateLabel];
            const items = group.items || group; // 後方互換性のため
            const count = items.length;
            
            html += `
                <div class="entry-registered-date-group" style="margin-bottom: 20px; margin-top: 0; padding-top: 0; height: auto; min-height: 0;">
                    <div style="display: flex; align-items: center; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); margin-top: 0; padding-top: 0; height: auto; min-height: 0; line-height: 1.2;">
                        <h4 style="margin: 0; padding: 0; font-size: 1rem; font-weight: 600; color: var(--accent-blue); line-height: 1.2; height: auto;">${dateLabel}</h4>
                        <span style="margin-left: 12px; font-size: 0.85rem; color: var(--text-muted); line-height: 1.2;">(${count}台)</span>
                    </div>
                    ${items.map(batch => {
                        // 詳細情報を1行で表示（適切に折り返される）
                        const details = [
                            batch.driver ? `ドライバー: ${batch.driver}` : '',
                            batch.capacity ? `積載: ${batch.capacity}m³` : '',
                            batch.category ? `車種: ${batch.category}` : ''
                        ].filter(Boolean).join(' | ');
                        
                        return `
                            <div class="entry-registered-item" style="padding: 12px; margin-bottom: 8px; background: rgba(255, 255, 255, 0.05); border-radius: 8px; border-left: 3px solid var(--accent-blue);">
                                <div style="display: flex; flex-wrap: wrap; gap: 12px; align-items: flex-start;">
                                    <div style="flex: 1; min-width: 200px;">
                                        <div style="font-weight: bold; margin-bottom: 6px; font-size: 0.95rem; word-break: break-word;">${batch.name || '未設定'}</div>
                                        <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 6px; word-break: break-word;">${batch.company || '未設定'}</div>
                                        ${details ? `<div style="font-size: 0.75rem; color: var(--text-muted); line-height: 1.5; word-break: break-word; white-space: normal;">${details}</div>` : ''}
                                    </div>
                                    <div style="flex-shrink: 0;">
                                        <button class="glass-btn primary small" style="white-space: nowrap;" onclick="assignTruck('${batch.id}', '${String(batch.name || '').replace(/'/g, "\\'")}')">配車へ進む</button>
                                    </div>
                                </div>
                            </div>
                        `;
                    }).join('')}
                </div>
            `;
        });
        
        showDebugInfo(`HTML生成完了。HTML長: ${html.length}文字`);
        
        // すべてのリスト要素に同じ内容を表示
        showDebugInfo(`HTMLをリスト要素に設定します。リスト数: ${allLists.length}, HTML長: ${html.length}`);
        showDebugInfo(`HTMLの最初の200文字: ${html.substring(0, 200)}...`);
        
        allLists.forEach((list, index) => {
            if (list) {
                // 設定前の状態を確認
                const beforeContent = list.innerHTML;
                showDebugInfo(`リスト${index + 1}設定前の内容長: ${beforeContent.length}文字`);
                
                // HTMLを設定
                list.innerHTML = html;
                
                // 設定後の状態を確認
                const afterContent = list.innerHTML;
                showDebugInfo(`リスト${index + 1}設定後の内容長: ${afterContent.length}文字`);
                if (afterContent.length > 0) {
                    showDebugInfo(`リスト${index + 1}設定後の最初の300文字: ${afterContent.substring(0, 300)}...`);
                } else {
                    showDebugInfo(`⚠️ リスト${index + 1}設定後の内容が空です！`);
                }
                
                // 子要素を確認
                const children = list.children;
                showDebugInfo(`リスト${index + 1}の直接の子要素数: ${children.length}`);
                for (let i = 0; i < Math.min(children.length, 3); i++) {
                    const child = children[i];
                    showDebugInfo(`  子要素${i + 1}: ${child.tagName}, class=${child.className}, 内容の最初の100文字: ${child.textContent.substring(0, 100)}...`);
                }
                
                // DOM要素の表示状態を確認
                const computedStyle = window.getComputedStyle(list);
                showDebugInfo(`リスト${index + 1}の表示状態: display=${computedStyle.display}, visibility=${computedStyle.visibility}, opacity=${computedStyle.opacity}`);
                showDebugInfo(`リスト${index + 1}の高さ: height=${computedStyle.height}, max-height=${computedStyle.maxHeight}, overflow-y=${computedStyle.overflowY}`);
                
                // 親要素の表示状態も確認
                const parent = list.parentElement;
                if (parent) {
                    const parentStyle = window.getComputedStyle(parent);
                    showDebugInfo(`リスト${index + 1}の親要素の表示状態: display=${parentStyle.display}, visibility=${parentStyle.visibility}`);
                    showDebugInfo(`リスト${index + 1}の親要素の高さ: height=${parentStyle.height}, max-height=${parentStyle.maxHeight}`);
                }
                
                // 実際に表示されている要素の数を確認（より詳細に）
                const visibleItems = Array.from(list.querySelectorAll('.entry-registered-item')).filter(item => {
                    const itemStyle = window.getComputedStyle(item);
                    const itemRect = item.getBoundingClientRect();
                    return itemStyle.display !== 'none' && 
                           itemStyle.visibility !== 'hidden' && 
                           itemStyle.opacity !== '0' &&
                           itemRect.height > 0 &&
                           itemRect.width > 0;
                });
                showDebugInfo(`リスト${index + 1}内で実際に表示されている.entry-registered-item数: ${visibleItems.length}`);
                
                // 非表示になっている要素を特定
                const hiddenItems = Array.from(list.querySelectorAll('.entry-registered-item')).filter(item => {
                    const itemStyle = window.getComputedStyle(item);
                    const itemRect = item.getBoundingClientRect();
                    return itemStyle.display === 'none' || 
                           itemStyle.visibility === 'hidden' || 
                           itemStyle.opacity === '0' ||
                           itemRect.height === 0 ||
                           itemRect.width === 0;
                });
                if (hiddenItems.length > 0) {
                    showDebugInfo(`⚠️ リスト${index + 1}内で非表示になっている.entry-registered-item数: ${hiddenItems.length}`);
                    hiddenItems.forEach((item, idx) => {
                        if (idx < 3) {
                            const nameEl = item.querySelector('div[style*="font-weight: bold"]');
                            const name = nameEl ? nameEl.textContent.trim() : '名前なし';
                            const itemStyle = window.getComputedStyle(item);
                            showDebugInfo(`  非表示エントリ${idx + 1}: ${name} - display: ${itemStyle.display}, visibility: ${itemStyle.visibility}, opacity: ${itemStyle.opacity}, height: ${item.getBoundingClientRect().height}px`);
                        }
                    });
                }
                
                // さらに詳細な確認：entry-registered-itemの数を確認
                const items = list.querySelectorAll('.entry-registered-item');
                showDebugInfo(`リスト${index + 1}内の.entry-registered-item数: ${items.length}`);
                
                // スクロール位置を確認
                showDebugInfo(`リスト${index + 1}のスクロール位置: scrollTop=${list.scrollTop}px, scrollHeight=${list.scrollHeight}px, clientHeight=${list.clientHeight}px`);
                
                if (items.length > 0) {
                    items.forEach((item, idx) => {
                        // すべてのエントリを表示（制限なし）
                        const nameEl = item.querySelector('div[style*="font-weight: bold"]');
                        const name = nameEl ? nameEl.textContent.trim() : '名前なし';
                        
                        // 各エントリの表示状態を確認
                        const itemStyle = window.getComputedStyle(item);
                        const itemRect = item.getBoundingClientRect();
                        const listRect = list.getBoundingClientRect();
                        
                        // リストの表示領域内にあるか確認
                        const isInViewport = itemRect.top >= listRect.top && 
                                           itemRect.bottom <= listRect.bottom;
                        const isPartiallyVisible = itemRect.bottom > listRect.top && 
                                                  itemRect.top < listRect.bottom;
                        
                        const isVisible = itemStyle.display !== 'none' && 
                                         itemStyle.visibility !== 'hidden' && 
                                         itemStyle.opacity !== '0' &&
                                         itemRect.height > 0 &&
                                         itemRect.width > 0;
                        
                        showDebugInfo(`  エントリ${idx + 1}: ${name} - 表示: ${isVisible ? '✅' : '❌'}, 高さ: ${itemRect.height}px, 幅: ${itemRect.width}px, 表示領域内: ${isInViewport ? '✅' : isPartiallyVisible ? '一部' : '❌'}, 位置: top=${itemRect.top}px`);
                    });
                } else {
                    showDebugInfo(`⚠️ リスト${index + 1}内に.entry-registered-itemが見つかりません！`);
                    // 日付グループ内の要素を確認
                    const dateGroups = list.querySelectorAll('.entry-registered-date-group');
                    showDebugInfo(`日付グループ数: ${dateGroups.length}`);
                    dateGroups.forEach((group, gIdx) => {
                        const groupItems = group.querySelectorAll('div[class*="entry-registered-item"]');
                        showDebugInfo(`  グループ${gIdx + 1}内の要素数: ${groupItems.length}`);
                    });
                }
                
                // 子要素の数を確認
                const childCount = list.children.length;
                showDebugInfo(`リスト${index + 1}の子要素数: ${childCount}`);
                
                // リストの位置を確認
                const listRect = list.getBoundingClientRect();
                const firstChild = list.firstElementChild;
                if (firstChild) {
                    const firstChildRect = firstChild.getBoundingClientRect();
                    const offset = firstChildRect.top - listRect.top;
                    showDebugInfo(`リスト${index + 1}の先頭要素のオフセット: ${offset}px`);
                    
                    // 日付グループ内の最初のエントリの位置を確認
                    const firstEntry = firstChild.querySelector('.entry-registered-item');
                    if (firstEntry) {
                        const firstEntryRect = firstEntry.getBoundingClientRect();
                        const entryOffset = firstEntryRect.top - firstChildRect.top;
                        showDebugInfo(`日付グループ内の最初のエントリのオフセット: ${entryOffset}px`);
                        if (entryOffset > 100) {
                            showDebugInfo(`⚠️ 日付グループ内に${entryOffset}pxの空白があります！`);
                            // 見出し部分の高さを確認
                            const headerDiv = firstChild.querySelector('div:first-child');
                            if (headerDiv) {
                                const headerRect = headerDiv.getBoundingClientRect();
                                showDebugInfo(`見出し部分の高さ: ${headerRect.height}px`);
                                showDebugInfo(`見出し部分の位置: top=${headerRect.top}px, bottom=${headerRect.bottom}px`);
                                showDebugInfo(`見出し部分からエントリまでの距離: ${firstEntryRect.top - headerRect.bottom}px`);
                            }
                        }
                    }
                }
                
                // スクロール位置を先頭に戻す（新規登録後など）
                // DOM更新後に確実にスクロール位置を0に設定
                requestAnimationFrame(() => {
                    list.scrollTop = 0;
                    showDebugInfo(`リスト${index + 1}のスクロール位置を先頭に設定しました（requestAnimationFrame後）`);
                    // 念のため、もう一度確認
                    setTimeout(() => {
                        if (list.scrollTop !== 0) {
                            list.scrollTop = 0;
                            showDebugInfo(`リスト${index + 1}のスクロール位置を再設定しました（setTimeout後）`);
                        }
                    }, 0);
                });
                
                showDebugInfo(`✅ リスト${index + 1}にHTMLを設定しました。`);
            } else {
                showDebugInfo(`⚠️ リスト${index + 1}がnullです。`);
            }
        });
        showDebugInfo('✅ renderEntryRegistered 完了');
        } catch (e) {
            showDebugInfo(`❌ renderEntryRegistered エラー: ${e.message}`);
            showDebugInfo(`エラースタック: ${e.stack}`);
            // エラーが発生しても、空のメッセージを表示
            const dashboardList = document.getElementById('entry-registered-list-dashboard');
            const errorLists = dashboardList ? [dashboardList] : [];
            errorLists.forEach(list => {
                if (list) {
                    list.innerHTML = '<div style="text-align: center; padding: 20px; color: var(--text-muted);">表示エラーが発生しました</div>';
                }
            });
        }
    }

