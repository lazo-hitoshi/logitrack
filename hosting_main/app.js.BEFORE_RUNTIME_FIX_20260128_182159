    function exportHistoryToCSV() {
        const dateFilterEl = document.getElementById('history-date-filter');
        const selectedDate = dateFilterEl?.value || '';
        const toDateKey = (value) => {
            if (!value) return '';
            const s = String(value);
            const m = s.match(/\d{4}-\d{2}-\d{2}/);
            if (m) return m[0];
            const d = new Date(s);
            return Number.isNaN(d.getTime()) ? '' : d.toISOString().slice(0, 10);
        };
        const items = selectedDate
            ? state.history.filter(item => toDateKey(item.completedAt) === selectedDate)
            : state.history;

        const headers = ['完了日時', 'ロット番号', '船名/車両', '会社', '種別', '搬入先', '積載量', '状態'];
        const rows = items.map(item => [
            item.completedAt || '',
            item.id || '',
            item.name || '',
            item.company || '',
            item.type === 'sea' ? '船舶' : 'ダンプ',
            item.site || '',
            item.amount || '',
            item.status || '完了'
        ]);

        const suffix = selectedDate || new Date().toISOString().slice(0, 10);
        downloadCsv(`運搬履歴_${suffix}.csv`, headers, rows);
    }

