    window.clearEntryRegistered = function() {
        if (!confirm('入場登録済み（配車待ち）のデータを全て削除しますか？')) {
            return;
        }
        
        // state変数を取得（window.stateから取得）
        const currentState = window.state || state;
        if (!currentState || !currentState.batches) {
            alert('システムが初期化されていません。ページをリロードしてください。');
            return;
        }
        
        const beforeCount = currentState.batches.length;
        showDebugInfo(`削除前のバッチ数: ${beforeCount}`);
        
        // entry_registeredステータスのバッチのみを削除対象とする
        const entryRegisteredBatches = currentState.batches.filter(b => {
            try {
                // 陸上バッチであること（typeが'land'または未定義）
                if (b.type && b.type !== 'land') {
                    return false;
                }
                
                // 完了していないこと
                if (b.status === '完了') {
                    return false;
                }
                
                // ステータスが entry_registered のみを削除対象とする
                // （standby、積込待ちなどは他の画面で表示されるため除外）
                if (b.status === 'entry_registered') {
                    return true;
                }
                
                return false;
            } catch (e) {
                console.error('フィルタ処理エラー:', e, b);
                return false;
            }
        });
        
        showDebugInfo(`削除対象のバッチ数: ${entryRegisteredBatches.length}`);
        entryRegisteredBatches.forEach(b => {
            showDebugInfo(`削除対象: ${b.name} (status=${b.status}, notes=${b.notes || 'なし'}, portEntryDate=${b.portEntryDate || 'なし'})`);
        });
        
        // 削除対象のIDを取得
        const deleteIds = new Set(entryRegisteredBatches.map(b => b.id));
        
        // 削除対象を除外
        currentState.batches = currentState.batches.filter(b => !deleteIds.has(b.id));
        const afterCount = currentState.batches.length;
        const deletedCount = beforeCount - afterCount;

        // Firestore側も削除
        deleteIds.forEach(id => firestoreDeleteLot(id).catch(() => {}));
        
        // state変数も更新
        if (state && state.batches) {
            state.batches = currentState.batches;
        }
        
        // window.stateも更新
        if (window.state) {
            window.state.batches = currentState.batches;
        }
        
        showDebugInfo(`削除後のバッチ数: ${afterCount}`);
        showDebugInfo(`削除された数: ${deletedCount}`);
        
        // 状態を保存
        if (typeof saveState === 'function') {
            saveState();
            showDebugInfo('saveState()を実行しました');
        }
        
        // 表示を更新
        if (typeof renderEntryRegistered === 'function') {
            renderEntryRegistered();
            showDebugInfo('renderEntryRegistered()を実行しました');
        }
        if (typeof renderBatches === 'function') {
            renderBatches();
            showDebugInfo('renderBatches()を実行しました');
        }
        
        showDebugInfo(`✅ 入場登録済みデータを削除しました: ${deletedCount}件`);
        alert(`${deletedCount}件の入場登録済みデータを削除しました。`);
        console.log(`入場登録済みデータを削除: ${deletedCount}件`);
    };
    
    // --- デバッグ用: 入場登録データの確認関数
    window.checkEntryRegistered = function() {
        console.log('=== 入場登録データの確認 ===');
        const allBatches = state.batches;
        console.log('全バッチ数:', allBatches.length);
        
        const entryRegistered = allBatches.filter(b => 
            b.type === 'land' && 
            (b.status === 'entry_registered' || b.status === 'standby')
        );
        
        console.log('入場登録済みバッチ数:', entryRegistered.length);
        if (entryRegistered.length > 0) {
            console.log('入場登録済みバッチ一覧:');
            entryRegistered.forEach(b => {
                console.log(`  - ${b.name} (ステータス: ${b.status}, ロットID: ${b.id})`);
            });
        } else {
            console.log('入場登録済みのバッチはありません');
        }
        
        // 表示場所の確認
        const entryList = document.getElementById('entry-registered-list');
        const batchTable = document.querySelector('#batch-table tbody');
        console.log('表示要素の確認:');
        console.log('  - entry-registered-list要素:', entryList ? '存在' : '存在しない');
        console.log('  - batch-table tbody要素:', batchTable ? '存在' : '存在しない');
        
        if (entryList) {
            console.log('  - entry-registered-listの内容:', entryList.innerHTML.substring(0, 100));
        }
        
        return {
            totalBatches: allBatches.length,
            entryRegistered: entryRegistered.length,
            batches: entryRegistered
        };
    };

    // --- Init ---
    // 入場登録モーダルが存在するか確認し、存在しない場合は動的生成
    try {
        ensureTruckModalExists();
    } catch (e) {
        console.error('ensureTruckModalExists エラー:', e);
    }
    
    // 初期レンダリング（エラーハンドリング付き）
    function initializeApp() {
        showDebugInfo('初期レンダリング開始');

        // Firestoreから読み込み（初回のみ）。完了後に通常レンダリング。
        if (!window.__firestoreBootstrapped) {
            window.__firestoreBootstrapped = true;
            ensureFirestoreLoadedOnce()
                .catch(() => false)
                .finally(() => {
                    try {
                        initializeApp();
                    } catch (_) {
                        // noop
                    }
                });
            return;
        }
        
        try {
            if (typeof renderBatches === 'function') {
                renderBatches();
                showDebugInfo('renderBatches完了');
            } else {
                showDebugInfo('renderBatches関数が定義されていません');
            }
        } catch (e) {
            console.error('renderBatches エラー:', e);
            showDebugInfo('renderBatches エラー: ' + e.message);
        }
        
        try {
            if (typeof renderHistory === 'function') {
                renderHistory();
                showDebugInfo('renderHistory完了');
            } else {
                showDebugInfo('renderHistory関数が定義されていません');
            }
        } catch (e) {
            console.error('renderHistory エラー:', e);
            showDebugInfo('renderHistory エラー: ' + e.message);
        }
        
        try {
            if (typeof renderAlerts === 'function') {
                renderAlerts();
                showDebugInfo('renderAlerts完了');
            } else {
                showDebugInfo('renderAlerts関数が定義されていません');
            }
        } catch (e) {
            console.error('renderAlerts エラー:', e);
            showDebugInfo('renderAlerts エラー: ' + e.message);
        }
        
        try {
            if (typeof renderEntryRegistered === 'function') {
                renderEntryRegistered();
                showDebugInfo('renderEntryRegistered完了');
            } else {
                showDebugInfo('renderEntryRegistered関数が定義されていません');
            }
        } catch (e) {
            console.error('renderEntryRegistered エラー:', e);
            showDebugInfo('renderEntryRegistered エラー: ' + e.message);
        }
        
        try {
            if (typeof renderBatchFilter === 'function') {
                renderBatchFilter();
                showDebugInfo('renderBatchFilter完了');
            } else {
                showDebugInfo('renderBatchFilter関数が定義されていません');
            }
        } catch (e) {
            console.error('renderBatchFilter エラー:', e);
            showDebugInfo('renderBatchFilter エラー: ' + e.message);
        }
        
        try {
            if (typeof updateFormOptions === 'function') {
                updateFormOptions();
                showDebugInfo('updateFormOptions完了');
            } else {
                showDebugInfo('updateFormOptions関数が定義されていません');
            }
        } catch (e) {
            console.error('updateFormOptions エラー:', e);
            showDebugInfo('updateFormOptions エラー: ' + e.message);
        }
        
        try {
            // マップの再初期化を試みる
            if (typeof initMaps === 'function') {
                initMaps();
                showDebugInfo('マップ再初期化完了');
            }
            if (typeof drawMap === 'function') {
                drawMap();
                showDebugInfo('drawMap完了');
            } else {
                showDebugInfo('drawMap関数が定義されていません');
            }
        } catch (e) {
            console.error('drawMap エラー:', e);
            showDebugInfo('drawMap エラー: ' + e.message);
        }
        
        showDebugInfo('初期レンダリング完了');
    }
    
    // 即座に初期化
    try {
        initializeApp();
    } catch (e) {
        console.error('初期化エラー:', e);
        showDebugInfo('初期化エラー: ' + e.message);
    }
    
    // 念のため、少し遅延させて再度レンダリング
    setTimeout(() => {
        try {
            showDebugInfo('遅延レンダリング開始');
            initializeApp();
        } catch (e) {
            console.error('遅延レンダリング エラー:', e);
            showDebugInfo('遅延レンダリング エラー: ' + e.message);
        }
    }, 500);

        // Check for AppSheet Masters
        try {
            fetchAppSheetMasters();
        } catch (e) {
            console.error('fetchAppSheetMasters エラー:', e);
        }

        // ボタンの存在確認
        const openModalBtnCheck = document.getElementById('open-modal-btn');
        const openTruckBtnCheck = document.getElementById('open-truck-modal-btn');
        console.log('ボタンの確認:', {
            'open-modal-btn': openModalBtnCheck ? '存在' : '存在しない',
            'open-truck-modal-btn': openTruckBtnCheck ? '存在' : '存在しない'
        });
        
        if (!openModalBtnCheck) {
            console.error('open-modal-btn が見つかりません！');
        }
        if (!openTruckBtnCheck) {
            console.error('open-truck-modal-btn が見つかりません！');
        }
        
        console.log('[LogiTrack] 初期化完了');
        showDebugInfo('初期化処理完了');
        isInitialized = true; // 初期化完了をマーク
    } catch (e) {
        console.error('初期化全体エラー:', e);
        showDebugInfo('初期化全体エラー: ' + e.message);
        showDebugInfo('スタック: ' + (e.stack || 'スタック情報なし'));
        alert('アプリケーションの初期化中にエラーが発生しました: ' + e.message + '\nページをリロードしてください。\nデバッグ情報を確認してください。');
        // エラーが発生してもフラグを設定して無限ループを防ぐ
        isInitialized = true;
    }
}

// DOMContentLoadedで初期化
document.addEventListener('DOMContentLoaded', () => {
    try {
        showDebugInfo('DOMContentLoaded 発火');
        initializeApplication();
    } catch (e) {
        console.error('DOMContentLoaded 初期化エラー:', e);
        showDebugInfo('DOMContentLoaded 初期化エラー: ' + e.message);
    }
});

// window.onloadでも初期化（念のため）
window.addEventListener('load', () => {
    try {
        console.log('[LogiTrack] window.onload 発火');
        showDebugInfo('window.onload 発火');
        // DOMContentLoadedで既に初期化されている可能性があるが、念のため再初期化
        setTimeout(() => {
            try {
                showDebugInfo('window.onload 遅延初期化開始');
                initializeApplication();
            } catch (e) {
                console.error('window.onload 初期化エラー:', e);
                showDebugInfo('window.onload 初期化エラー: ' + e.message);
            }
        }, 100);
    } catch (e) {
        console.error('window.onload イベントリスナーエラー:', e);
        showDebugInfo('window.onload イベントリスナーエラー: ' + e.message);
    }
});





