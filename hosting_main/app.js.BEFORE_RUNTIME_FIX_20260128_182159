    function setupPortScheduleView() {
        if (portScheduleSetupDone) return;
        portScheduleSetupDone = true;

        // タブ切替（カレンダー / PDF-JPG）
        const tabCalendarBtn = document.getElementById('port-schedule-tab-calendar');
        const tabPreviewBtn = document.getElementById('port-schedule-tab-preview');
        const calendarWrap = document.getElementById('port-schedule-calendar-wrap');
        const previewWrap = document.getElementById('port-schedule-preview-wrap');
        const applyTab = (tab) => {
            const isCalendar = tab === 'calendar';
            if (calendarWrap) calendarWrap.style.display = isCalendar ? '' : 'none';
            if (previewWrap) previewWrap.style.display = isCalendar ? 'none' : '';
            if (tabCalendarBtn) tabCalendarBtn.classList.toggle('primary', isCalendar);
            if (tabCalendarBtn) tabCalendarBtn.classList.toggle('secondary', !isCalendar);
            if (tabPreviewBtn) tabPreviewBtn.classList.toggle('primary', !isCalendar);
            if (tabPreviewBtn) tabPreviewBtn.classList.toggle('secondary', isCalendar);
        };
        tabCalendarBtn?.addEventListener('click', () => applyTab('calendar'));
        tabPreviewBtn?.addEventListener('click', () => applyTab('preview'));
        // デフォルトは「カレンダー」を表示
        applyTab('calendar');

        const fileInput = document.getElementById('port-schedule-file');
        const sampleFileInput = document.getElementById('port-schedule-sample-file');
        const clearBtn = document.getElementById('port-schedule-clear-btn');
        const empty = document.getElementById('port-schedule-empty');
        const pdf = document.getElementById('port-schedule-pdf');
        const img = document.getElementById('port-schedule-img');
        // 参考スクショ（存在する時だけ表示）
        const sampleWrap = document.getElementById('soma-port-sample-wrap');
        const sampleImg = document.getElementById('soma-port-sample-img');
        if (sampleImg && sampleWrap) {
            sampleImg.onload = () => { sampleWrap.style.display = ''; };
            sampleImg.onerror = () => { sampleWrap.style.display = 'none'; };
        }
        // 参考画像（ローカルから選んで表示・保存）
        const SAMPLE_LS_KEY = 'logitrack_port_schedule_sample_image';
        const applySampleDataUrl = (dataUrl) => {
            if (!sampleImg || !sampleWrap) return;
            if (!dataUrl) return;
            sampleImg.onload = () => { sampleWrap.style.display = ''; };
            sampleImg.onerror = () => { sampleWrap.style.display = 'none'; };
            sampleImg.src = dataUrl;
        };
        try {
            const saved = localStorage.getItem(SAMPLE_LS_KEY);
            if (saved) applySampleDataUrl(saved);
        } catch (_) { /* noop */ }
        sampleFileInput?.addEventListener('change', () => {
            const f = sampleFileInput.files?.[0];
            if (!f) return;
            const reader = new FileReader();
            reader.onload = () => {
                const dataUrl = String(reader.result || '');
                if (!dataUrl) return;
                try { localStorage.setItem(SAMPLE_LS_KEY, dataUrl); } catch (_) { /* noop */ }
                applySampleDataUrl(dataUrl);
            };
            reader.readAsDataURL(f);
        });

        const clearPreview = () => {
            if (portScheduleObjectUrl) {
                try { URL.revokeObjectURL(portScheduleObjectUrl); } catch (_) { /* noop */ }
                portScheduleObjectUrl = null;
            }
            if (pdf) {
                pdf.src = '';
                pdf.style.display = 'none';
            }
            if (img) {
                img.src = '';
                img.style.display = 'none';
            }
            if (empty) empty.style.display = '';
            if (fileInput) fileInput.value = '';
        };

        clearBtn?.addEventListener('click', (e) => {
            e.preventDefault();
            clearPreview();
        });

        fileInput?.addEventListener('change', () => {
            const file = fileInput.files?.[0];
            if (!file) {
                clearPreview();
                return;
            }
            // PDF/JPGを選んだら自動でプレビューに切り替える
            applyTab('preview');
            clearPreview();

            portScheduleObjectUrl = URL.createObjectURL(file);
            const isPdf = file.type === 'application/pdf' || /\.pdf$/i.test(file.name || '');
            if (isPdf && pdf) {
                if (empty) empty.style.display = 'none';
                pdf.src = portScheduleObjectUrl;
                pdf.style.display = '';
                return;
            }
            if (img) {
                if (empty) empty.style.display = 'none';
                img.src = portScheduleObjectUrl;
                img.style.display = '';
                return;
            }
            // 未対応
            alert('PDF または 画像（JPG/PNG 等）を選択してください。');
            clearPreview();
        });
    }

