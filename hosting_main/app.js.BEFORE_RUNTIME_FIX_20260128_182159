    // --- CSV Export (Improved) ---
    function escapeCsvValue(v) {
        return `"${String(v ?? '').replace(/"/g, '""')}"`;
    }

    function downloadCsv(filename, headers, rows) {
        let csvContent = '\uFEFF' + headers.join(',') + '\n';
        rows.forEach(row => {
            csvContent += row.map(escapeCsvValue).join(',') + '\n';
        });
        const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = filename;
        link.click();
    }

    function exportToCSV() {
        const headers = ['ID', '名前', '会社', 'プラント', '種別', '土質', '現場', '状態', '進捗', '船員数', '元船ID', '備考'];
        const rows = state.batches.map(b => [
            b.id, b.name, b.company, b.plant,
            b.type === 'sea' ? '船舶' : 'ダンプ',
            b.soilType, b.site, b.status, `${b.progress}%`,
            b.crew || '-', b.parentShipId || '', b.notes || ''
        ]);
        downloadCsv(`運行状況一覧_${new Date().toISOString().slice(0, 10)}.csv`, headers, rows);
    }

    // --- Rendering ---
    function renderBatches() {
        try {
            const seaBody = document.querySelector('#batch-table-sea tbody');
            const landBody = document.querySelector('#batch-table-land tbody');
            if (!seaBody && !landBody) return;
            if (seaBody) seaBody.innerHTML = '';
            if (landBody) landBody.innerHTML = '';

            const statusOrder = { 'entry_registered': 0, 'standby': 1 };
            const sortedBatches = [...state.batches].sort((a, b) => {
                const aOrder = statusOrder[a.status] ?? 2;
                const bOrder = statusOrder[b.status] ?? 2;
                return aOrder - bOrder;
            });

            const renderRows = (targetBody, batches, isLandTable) => {
                if (!targetBody) return;
                batches.forEach(batch => {
                    const tr = document.createElement('tr');
                    if (batch.notes) tr.title = `備考: ${batch.notes}`;

                    const docBadges = batch.docs.length > 0
                        ? batch.docs.map(d => {
                            const name = typeof d === 'string' ? d : d.name;
                            const label = typeof d === 'string'
                                ? (d === '分析表' ? '📊' : '📜')
                                : (d.type === 'analysis' ? '📊' : (d.type === 'proof' ? '📜' : '📎'));
                            return `<span class="doc-badge" title="${name}">${label}</span>`;
                        }).join('')
                        : '<span class="text-muted" style="font-size: 0.7rem;">未提出</span>';

                    const companyInfo = [
                        batch.name,
                        batch.crew && batch.crew !== '-' ? `(${batch.crew}名)` : '',
                        batch.company,
                        batch.plant ? `🏭 ${batch.plant}` : ''
                    ].filter(Boolean).join(' / ');

                    const parentShipInfo = isLandTable
                        ? (() => {
                            if (!batch.parentShipId) return '-';
                            const ship = state.batches.find(b => b.id === batch.parentShipId);
                            return ship ? `${ship.name} (${ship.id})` : batch.parentShipId;
                        })()
                        : null;

                    const typeInfo = [
                        batch.soilType || '',
                        docBadges
                    ].filter(Boolean).join(' ');

                    const safeName = String(batch.name || '').replace(/'/g, "\\'");
                    const actionBtn = isLandTable
                        ? `<div style="display:inline-flex; gap:8px; align-items:center;">
                               <button class="detail-btn" onclick="assignTruck('${batch.id}', '${safeName}')">配車情報</button>
                               <button class="detail-btn" onclick="editBatch('${batch.id}')">編集</button>
                           </div>`
                        : `<button class="detail-btn" onclick="editBatch('${batch.id}')">編集</button>`;

                    tr.innerHTML = `
                        <td style="white-space: nowrap;">${batch.id}</td>
                        <td class="company-cell" style="white-space: nowrap;">${companyInfo}</td>
                        ${isLandTable ? `<td style="white-space: nowrap;">${parentShipInfo}</td>` : ''}
                        <td style="white-space: nowrap;"><span class="badge ${batch.type}">${batch.type === 'sea' ? '🛳' : '🚛'}</span></td>
                        <td style="white-space: nowrap;">${typeInfo}</td>
                        <td style="white-space: nowrap;">${batch.site || '-'}</td>
                        <td style="white-space: nowrap;">${batch.location || '-'}</td>
                        <td style="white-space: nowrap;">${batch.status}</td>
                        <td style="white-space: nowrap;">${actionBtn}</td>
                    `;
                    targetBody.appendChild(tr);
                });
            };

            renderRows(seaBody, sortedBatches.filter(b => b.type === 'sea'), false);
            renderRows(landBody, sortedBatches.filter(b => b.type !== 'sea'), true);

            renderShipTracking();
            renderTruckTracking();
        } catch (e) {
            console.error('renderBatches エラー:', e);
        }
    }

    function renderShipTracking() {
        const grid = document.getElementById('ship-grid');
        const count = document.getElementById('ship-active-count');
        if (!grid) return;

        const ships = state.batches.filter(b => b.type === 'sea');
        if (count) count.textContent = ships.length;

        grid.innerHTML = ships.length ? '' : '<p class="text-muted">稼働中の船舶はありません</p>';

        ships.forEach(s => {
            const card = document.createElement('div');
            card.className = 'ship-card glass';

            // 3-Day Rule Logic
            let daysInfo = '';
            if (s.arrivalDate && s.status !== '完了') {
                const arrival = new Date(s.arrivalDate);
                const now = new Date();
                const diffTime = Math.abs(now - arrival);
                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

                let color = 'var(--accent-green)';
                if (diffDays === 3) color = '#facc15'; // Warning
                if (diffDays > 3) color = '#ef4444'; // Overdue

                daysInfo = `<div style="font-size: 0.8rem; margin-top: 4px; color: ${color}; font-weight: bold;">
                    搬出: ${diffDays}日目 / 期限3日
                </div>`;
            }

            card.innerHTML = `
                <div class="ship-header">
                    <div>
                        <div class="ship-name">${s.name}</div>
                        <div class="ship-meta">${s.company}</div>
                        <div style="font-size: 0.7rem; color: #94a3b8;">${s.id}</div>
                    </div>
                    <span class="badge sea">🛳</span>
                </div>
                <div style="display: flex; justify-content: space-between; font-size: 0.9rem;">
                    <span>現在地: ${s.status === '輸送中' ? '航海中' : s.location}</span>
                    <span>${s.progress.toFixed(0)}%</span>
                </div>
                <div class="progress-bar"><div class="progress" style="width: ${s.progress}%"></div></div>
                <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 4px;">
                    積荷: ${s.soilType} / ${s.plant || '-'}
                </div>
                ${daysInfo}
            `;
            grid.appendChild(card);
        });
    }

    function renderTruckTracking() {
        const lists = {
            'standby': document.getElementById('list-standby'),
            '輸送中': document.getElementById('list-transport')
        };
        const counts = {
            'standby': document.getElementById('count-standby'),
            '輸送中': document.getElementById('count-transport')
        };

        // Clear lists
        Object.values(lists).forEach(l => { if (l) l.innerHTML = ''; });

        // 船名リストを取得（船名を除外するため）
        const vesselNames = state.masters?.vessels || [];
        
                // 19時以降は「輸送中（本日港通行予定）」を履歴へ移動（消えない版：先に履歴、最後に削除）
        const histNow = new Date();
        const histTodayStr = `${histNow.getFullYear()}-${String(histNow.getMonth() + 1).padStart(2, '0')}-${String(histNow.getDate()).padStart(2, '0')}`;


        if (!Array.isArray(state.history)) state.history = [];

        const moveItems = [];
        state.batches.forEach(b => {
            if (b.type !== 'land') return;
            if (b.status !== '輸送中') return;
            if (!b.dispatchDate) return;
            if (b.dispatchDate !== todayStr) return;
            if (now.getHours() < 19) return;
            moveItems.push(b);
        });

        if (moveItems.length) {
            const toMoveIds = new Set();

            moveItems.forEach(b => {
                const historyItem = {
                    id: b.id,
                    name: b.name,
                    company: b.company,
                    type: b.type,
                    location: b.location,
                    status: '完了',
                    site: b.site,
                    completedAt: new Date().toISOString().slice(0, 16).replace('T', ' '),
                    amount: b.capacity || ''
                };

                // 先に履歴に入れる（これで“消える”が起きにくい）
                state.history.push(historyItem);

                // Firestoreは失敗してもOK（履歴一覧は残る）
                firestoreUpsertHistory(historyItem).catch(() => {});
                toMoveIds.add(b.id);
            });

            // 最後に active から削除
            state.batches = state.batches.filter(b => !(b && toMoveIds.has(b.id)));
            toMoveIds.forEach(id => firestoreDeleteLot(id).catch(() => {}));

            saveState();
        }
                // (重複していた19時移行ブロックを削除しました)

// ダンプ位置画面には、当日になった entry_registered も移行対象に含める
        // また、船名（vessels）も除外する（誤ってtype=landで登録された船を除外）
        const trucks = state.batches.filter(b => {
            // type=land、かつ船名でないもののみ
            const isLand = b.type === 'land';
            const isNotVessel = !vesselNames.includes(b.name);
            return isLand && isNotVessel;
        });

        // 今日の日付を取得
        const today = new Date(now);
        today.setHours(0, 0, 0, 0);
        // Count Map
        const countMap = { 'standby': 0, '輸送中': 0 };

        let statusChanged = false;
        trucks.forEach(t => {
            const originalStatus = t.status || 'standby';
            let statusKey = originalStatus;
            let listKey = 'standby';
            
            // 港通行予定日が今日の場合は「輸送中」列に表示（前日に配車が組まれ、当日になったら自動的に移動）
            // または、既に輸送中ステータスの場合は「輸送中」列に表示
            if (originalStatus === '輸送中') {
                listKey = '輸送中';
            } else {
                const dispatchDate = t.dispatchDate || '';
                if (dispatchDate && originalStatus === 'entry_registered') {
                    // 配車予定日が組まれたら「入場済み / 待機」へ移動
                    t.status = 'standby';
                    statusChanged = true;
                }
                if (dispatchDate === todayStr && t.status !== 'entry_registered') {
                    // 当日6:00以降に「輸送中」へ移動
                    const isAfterSix = now.getHours() >= 6;
                    if (!isAfterSix) {
                        listKey = 'standby';
                        statusKey = 'standby';
                        return;
                    }
                // 当日のバッチは「輸送中」列に表示（当日になったら自動的に移動）
                // ただし、キャンセル処理中のバッチ（window.originalBatchStatusが設定されている）は自動更新をスキップ
                if (window.originalBatchId && window.originalBatchId === t.id && window.originalBatchStatus) {
                    // キャンセル処理中のバッチは、元のステータスのままにする
                    listKey = 'standby';
                    statusKey = 'standby';
                } else {
                    listKey = '輸送中';
                    statusKey = '輸送中';
                    // ステータスがまだ更新されていない場合は、自動的に更新する
                    if (t.status !== '輸送中') {
                        t.status = '輸送中';
                        statusChanged = true;
                    }
                }
                } else if (originalStatus === 'standby' || originalStatus === '積込待ち' ) {
                // standbyまたは積込待ちは「入場済み/待機」列に表示（前日に配車が組まれた状態）
                listKey = 'standby';
                statusKey = 'standby'; // 表示用のステータスキーを統一
                } else {
                // その他のステータス（積込中、荷卸し中、荷卸し完了など）は表示しない
                return; // このダンプは表示しない
            }
            }

            countMap[statusKey] = (countMap[statusKey] || 0) + 1;

            const card = document.createElement('div');
            card.className = 'truck-card';

            // Parent Ship Lookup
            let parentInfo = '';
            if (t.parentShipId) {
                const parent = [...state.batches, ...state.history].find(s => s.id === t.parentShipId);
                const parentName = parent ? `${parent.name} (${parent.id})` : t.parentShipId; // Fallback to ID if not found
                parentInfo = `<div style="font-size: 0.75rem; color: var(--accent-blue); margin-top: 4px;">📦 元船: ${parentName}</div>`;
            } else if (t.parentShip) {
                // Legacy support
                parentInfo = `<div style="font-size: 0.75rem; color: var(--accent-blue); margin-top: 4px;">📦 元船: ${t.parentShip}</div>`;
            }

            // ダンプ位置画面では配車が完了しているため、「配車へ進む」ボタンは表示しない
            let actionBtn = '';

            card.innerHTML = `
                <div style="font-weight: bold; margin-bottom: 4px;">${t.name}</div>
                <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 8px;">${t.company}</div>
                <div style="display: flex; justify-content: space-between; font-size: 0.75rem;">
                    <span>${t.soilType || '-'}</span>
                    <span>${t.site || '未定'}</span>
                </div>
                ${parentInfo}
                ${actionBtn}
            `;
            
            // カードをクリック可能にする（「配車へ進む」ボタン以外の部分）
            card.style.cursor = 'pointer';
            card.style.transition = 'background-color 0.2s';
            card.addEventListener('mouseenter', () => {
                card.style.backgroundColor = 'rgba(255, 255, 255, 0.05)';
            });
            card.addEventListener('mouseleave', () => {
                card.style.backgroundColor = '';
            });
            
            // カードクリックイベント（「配車へ進む」ボタン以外をクリックした場合）
            card.addEventListener('click', (e) => {
                // ボタンやその子要素をクリックした場合は無視
                if (e.target.tagName === 'BUTTON' || e.target.closest('button')) {
                    return;
                }
                // バッチの詳細を表示・編集
                if (typeof window.editBatch === 'function') {
                    window.editBatch(t.id);
                } else if (typeof editBatch === 'function') {
                    editBatch(t.id);
                }
            });
            
            if (lists[listKey]) lists[listKey].appendChild(card);
        });

        if (statusChanged) {
            saveState();
        }

        // Update counts
        if (counts['standby']) counts['standby'].textContent = countMap['standby'] || 0;
        if (counts['輸送中']) counts['輸送中'].textContent = countMap['輸送中'] || 0;
    }

    function renderHistory() {
