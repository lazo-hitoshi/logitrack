    window.addEventListener('resize', () => {
        canvases.forEach((_, i) => resizeCanvas(i));
    });

    function resizeCanvas(index) {
        const mapContainers = [
            document.getElementById('map-canvas-1'),
            document.getElementById('map-canvas-2')
        ];
        if (!mapContainers[index] || !canvases[index]) {
            console.warn(`resizeCanvas: マップ${index + 1}のコンテナまたはcanvasが見つかりません`);
            return;
        }
        const width = mapContainers[index].clientWidth || 400;
        const height = mapContainers[index].clientHeight || 450;
