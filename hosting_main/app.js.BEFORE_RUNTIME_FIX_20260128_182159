    function saveShipPresetFromBatch(batch) {
        if (!batch || batch.type !== 'sea') return;
        if (!state?.masters) return;
        if (!Array.isArray(state.masters.shipPresets)) state.masters.shipPresets = [];

        const shipName = String(batch.name || '').trim();
        const company = String(batch.company || '').trim();
        const id = `${company}::${shipName}`.trim();
        if (!shipName || !company || !id) return;

        const preset = {
            id,
            shipName,
            company,
            soilType: batch.soilType || '',
            plant: batch.plant || '',
            grossTonnage: batch.grossTonnage || '',
            weightTonnage: batch.weightTonnage || '',
            volume: batch.volume || '',
            site: batch.site || '',
            location: batch.location || '',
            updatedAt: new Date().toISOString()
        };

        const idx = state.masters.shipPresets.findIndex(p => p && p.id === id);
        if (idx !== -1) state.masters.shipPresets[idx] = { ...state.masters.shipPresets[idx], ...preset };
        else state.masters.shipPresets.unshift(preset);

        // 上限（増えすぎ防止）
        if (state.masters.shipPresets.length > 50) {
            state.masters.shipPresets = state.masters.shipPresets.slice(0, 50);
        }
    }

    function forceDispatchTruckFields(batchOrId) {
        const batch = typeof batchOrId === 'string'
            ? state.batches.find(b => b.id === batchOrId)
            : batchOrId;
        if (!batch) return;

        const resolvedTruck = batch.truckId
            ? state.masters.trucks.find(t => t.id === batch.truckId)
            : null;
        const resolvedTruckName = batch.truckName
            || (resolvedTruck && resolvedTruck.name)
            || window.originalBatchName
            || batch.name
            || '';
        const resolvedCompany = (resolvedTruck && resolvedTruck.company) || batch.company || '';
        const resolvedDriver = (resolvedTruck && resolvedTruck.driver) || batch.driver || '';
        const resolvedCapacity = (resolvedTruck && resolvedTruck.capacity) || batch.capacity || '';
        const resolvedCategory = normalizeTruckCategory((resolvedTruck && resolvedTruck.category) || batch.category || '');

        if (resolvedTruckName) {
            batch.name = resolvedTruckName;
            const stateBatchIndex = state.batches.findIndex(b => b.id === batch.id);
            if (stateBatchIndex !== -1) {
                state.batches[stateBatchIndex].name = resolvedTruckName;
            }
        }

        const nameSelect = document.getElementById('lot-name');
        if (nameSelect) {
            nameSelect.innerHTML = '';
            if (resolvedTruckName) {
                nameSelect.add(new Option(resolvedTruckName, resolvedTruckName));
                nameSelect.value = resolvedTruckName;
            }
            nameSelect.disabled = false;
            nameSelect.style.display = '';
        }

        const companyEl = document.getElementById('lot-company');
        if (companyEl) {
            const options = Array.from(companyEl.options).map(o => o.value);
            if (!options.includes(resolvedCompany) && resolvedCompany) {
                companyEl.add(new Option(resolvedCompany, resolvedCompany));
            }
            companyEl.value = resolvedCompany;
            companyEl.disabled = true;
        }

        const driverEl = document.getElementById('lot-driver');
        if (driverEl) {
            driverEl.value = resolvedDriver;
            driverEl.readOnly = true;
        }

        const capacityEl = document.getElementById('lot-capacity');
        if (capacityEl) {
            capacityEl.value = resolvedCapacity;
            capacityEl.readOnly = true;
        }

        const categoryEl = document.getElementById('lot-truck-category');
        if (categoryEl) {
            ensureSelectHasOption(categoryEl, resolvedCategory);
            categoryEl.disabled = true;
        }
    }

