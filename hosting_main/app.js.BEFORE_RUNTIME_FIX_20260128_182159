        switch (status) {
            case '輸送中': return '#38bdf8'; // Blue
            case '積込待ち': return '#fb923c'; // Orange
            case '積込中': return '#facc15'; // Yellow
            case '荷卸し中': return '#4ade80'; // Green
            case '荷卸し完了': return '#a3e635'; // Lime
            case 'standby': return '#94a3b8'; // Grey (Standby)
            default: return '#94a3b8'; // Grey
        }
    }

    function generateLotId() {
        const now = new Date();
        const yyyy = now.getFullYear();
        const mm = String(now.getMonth() + 1).padStart(2, '0');
        const dd = String(now.getDate()).padStart(2, '0');
        const count = state.batches.length + 1;
        return `LOT-${yyyy}${mm}${dd}-${String(count).padStart(3, '0')}`;
    }

