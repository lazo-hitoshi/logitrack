    function normalizeMasterLists() {
        if (!state?.masters) return;
        if (Array.isArray(state.masters.vessels)) {
            state.masters.vessels = state.masters.vessels
                .map(v => (typeof v === 'string' ? v : (v?.name || '')))
                .filter(Boolean);
        }
        if (Array.isArray(state.masters.trucks)) {
            state.masters.trucks = state.masters.trucks
                .map(t => {
                    if (typeof t === 'string') return { name: t };
                    return t;
                })
                .filter(t => t && t.name);
        }

        // 車両区分マスタ（＋で追加できるように）
        if (!Array.isArray(state.masters.truckCategories)) {
            state.masters.truckCategories = [];
        }
        state.masters.truckCategories = state.masters.truckCategories
            .map(v => (typeof v === 'string' ? v : String(v || '')))
            .map(v => v.trim())
            .filter(Boolean);
        ['大型ダンプ', 'トレーラー'].forEach(v => {
            if (!state.masters.truckCategories.includes(v)) state.masters.truckCategories.push(v);
        });

        // 既存データのカテゴリも正規化（表示されない/空になるのを防ぐ）
        if (Array.isArray(state.masters.trucks)) {
            state.masters.trucks.forEach(t => {
                if (t && t.category) t.category = normalizeTruckCategory(t.category);
            });
        }
        if (Array.isArray(state.batches)) {
            state.batches.forEach(b => {
                if (b && b.type === 'land' && b.category) b.category = normalizeTruckCategory(b.category);
            });
        }

        // 船テンプレ（前回入力）
        if (!Array.isArray(state.masters.shipPresets)) {
            state.masters.shipPresets = [];
        }
        state.masters.shipPresets = state.masters.shipPresets
            .filter(p => p && typeof p === 'object')
            .map(p => ({ ...p, id: String(p.id || '').trim() }))
            .filter(p => p.id);
    }

    function normalizeEntryBatches() {
        if (!state?.batches) return;
        const looksLikeTruck = (name) => /[0-9]/.test(name || '');
        state.batches.forEach(b => {
            if (b.type !== 'land') return;
            if (b.truckName) return;
            let resolved = '';
            if (b.truckId) {
                const t = state.masters.trucks.find(tr => tr.id === b.truckId);
                if (t?.name) resolved = t.name;
            }
            if (!resolved && looksLikeTruck(b.name)) {
                resolved = b.name;
            }
            if (!resolved && b.driver && b.company) {
                const t = state.masters.trucks.find(tr => tr.driver === b.driver && tr.company === b.company);
                if (t?.name) resolved = t.name;
            }
            if (resolved) {
                b.truckName = resolved;
                b.name = resolved;
            }
        });
    }

