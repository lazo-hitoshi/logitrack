        if (!tbody) return;
        const dateFilterEl = document.getElementById('history-date-filter');
        const selectedDate = dateFilterEl?.value || '';

        const toDateKey = (value) => {
            if (!value) return '';
            const s = String(value);
            const m = s.match(/\d{4}-\d{2}-\d{2}/);
            if (m) return m[0];
            const d = new Date(s);
            return Number.isNaN(d.getTime()) ? '' : d.toISOString().slice(0, 10);
        };

        const items = selectedDate
            ? state.history.filter(item => toDateKey(item.completedAt) === selectedDate)
            : state.history;

        if (items.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" style="text-align: center; padding: 20px; color: var(--text-muted);">履歴データはありません</td></tr>';
            return;
        }
        tbody.innerHTML = '';
        items.forEach(item => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${item.completedAt}</td>
                <td>${item.id}</td>
                <td>${item.name}</td>
