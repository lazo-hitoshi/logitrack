    // 船ごとにグループ化してマップに割り当て
    function getShipGroups() {
        const ships = state.batches.filter(b => b.type === 'sea' && (b.status === '輸送中' || b.status === '積込中' || b.status === '積込待ち'));
        const trucks = state.batches.filter(b => b.type === 'land' && (b.status === '輸送中' || b.status === '積込中' || b.status === '積込待ち'));
        
        // 船を2つのグループに分ける（最大2隻まで）
        const groups = [[], []];
        ships.forEach((ship, i) => {
            if (i < 2) {
                groups[i].push(ship);
                // この船に関連するダンプを追加
                const relatedTrucks = trucks.filter(t => t.parentShipId === ship.id);
                groups[i].push(...relatedTrucks);
            }
        });
        
        return groups;
    }

    // 進捗を計算（出港予定日または配車日+午前7時を基準）
    function calculateProgress(batch) {
        const now = new Date();
        
        if (batch.type === 'sea') {
            // 船：出港予定日を基準
            if (!batch.departureDate) return batch.progress || 0;
            const departureDate = new Date(batch.departureDate + 'T00:00:00');
            const daysSinceDeparture = (now.getTime() - departureDate.getTime()) / (1000 * 60 * 60 * 24);
            // 出港から3日で到着と仮定
            const totalDays = 3;
            return Math.min(Math.max((daysSinceDeparture / totalDays) * 100, 0), 100);
        } else {
            // ダンプ：配車日+午前7時を基準
            if (!batch.dispatchDate) return batch.progress || 0;
            const dispatchDateTime = new Date(batch.dispatchDate + 'T07:00:00');
            const hoursSinceDispatch = (now.getTime() - dispatchDateTime.getTime()) / (1000 * 60 * 60);
            // 配車から8時間で到着と仮定
            const totalHours = 8;
            return Math.min(Math.max((hoursSinceDispatch / totalHours) * 100, 0), 100);
        }
    }

    let frame = 0;
    function drawMap() {
        try {
            const groups = getShipGroups();
            
            groups.forEach((group, mapIndex) => {
                const ctx = contexts[mapIndex];
                const canvas = canvases[mapIndex];
                if (!ctx || !canvas) {
                    console.warn(`drawMap: マップ${mapIndex + 1}のctxまたはcanvasが見つかりません`);
                    return;
                }
                
                // canvasのサイズが0の場合は、再リサイズ
                if (canvas.width === 0 || canvas.height === 0) {
                    console.warn(`drawMap: マップ${mapIndex + 1}のサイズが0です。再リサイズします。`);
                    resizeCanvas(mapIndex);
                }
            
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            const w = canvas.width;
            const h = canvas.height;
            
            // サイズが0の場合は描画をスキップ
            if (w === 0 || h === 0) {
                console.warn(`drawMap: マップ${mapIndex + 1}のサイズが0のため、描画をスキップします。`);
                return;
            }
            
            // 背景を描画（マップが見えるように）
            ctx.fillStyle = 'rgba(15, 23, 42, 0.5)';
            ctx.fillRect(0, 0, w, h);
            
            // このグループの船を取得
            const ship = group.find(b => b.type === 'sea');
            const trucks = group.filter(b => b.type === 'land');
            
            // 埋立地は船ごとに異なる（船のsiteを使用、なければデフォルト）
            const landfillSite = ship?.site || (state && state.mapPoints && state.mapPoints.landfill && state.mapPoints.landfill.name) || '最終埋立地';
            
            // Locations - 水平に配置
            const points = {
                loading: { x: w * 0.12, y: h * 0.5 },
                landing: { x: w * 0.50, y: h * 0.5 },
                landfill: { x: w * 0.88, y: h * 0.5 }
            };
            
            // Sea Path
            ctx.beginPath();
            ctx.lineWidth = 3;
            ctx.setLineDash([8, 6]);
            ctx.strokeStyle = 'rgba(56, 189, 248, 0.5)';
            ctx.moveTo(points.loading.x, points.loading.y);
            ctx.lineTo(points.landing.x, points.landing.y);
            ctx.stroke();
            
            // Land Path
            ctx.beginPath();
            ctx.lineWidth = 3;
            ctx.setLineDash([8, 6]);
            ctx.strokeStyle = 'rgba(251, 146, 60, 0.5)';
            ctx.moveTo(points.landing.x, points.landing.y);
            ctx.lineTo(points.landfill.x, points.landfill.y);
            ctx.stroke();
            ctx.setLineDash([]);
            ctx.lineWidth = 1;
            
            // Draw Markers
            const loadingPortName = (state && state.mapPoints && state.mapPoints.loadingPort && state.mapPoints.loadingPort.name) || '積込港';
            const landingPortName = (state && state.mapPoints && state.mapPoints.landingPort && state.mapPoints.landingPort.name) || '相馬港';
            drawMarker(ctx, points.loading.x, points.loading.y, '#38bdf8', loadingPortName);
            drawMarker(ctx, points.landing.x, points.landing.y, '#38bdf8', landingPortName);
            drawMarker(ctx, points.landfill.x, points.landfill.y, '#10b981', landfillSite);
            
            // Draw Vehicles
            group.forEach(batch => {
                const isSea = batch.type === 'sea';
                const progress = calculateProgress(batch) / 100;
                let x, y;
                
                if (isSea) {
                    x = points.loading.x + (points.landing.x - points.loading.x) * progress;
                    y = points.loading.y + (points.landing.y - points.loading.y) * progress;
                } else {
                    x = points.landing.x + (points.landfill.x - points.landing.x) * progress;
                    y = points.landing.y + (points.landfill.y - points.landing.y) * progress;
                }
                
                drawVehicle(ctx, x, y, isSea ? '⛴' : '🚚', batch.name, isSea ? '#38bdf8' : '#fb923c');
            });
        });
        
        frame++;
        requestAnimationFrame(drawMap);
        } catch (e) {
            console.error('drawMap エラー:', e);
        }
    }

    function drawMarker(ctx, x, y, color, label) {
        ctx.fillStyle = color;
        ctx.beginPath();
        ctx.arc(x, y, 6, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = 'rgba(255,255,255,0.7)';
        ctx.font = '7px Inter';
        // ラベルの幅を計算して中央揃え、マーカーの下に配置
        const textWidth = ctx.measureText(label).width;
        ctx.fillText(label, x - textWidth / 2, y + 20);
    }

    function drawVehicle(ctx, x, y, icon, name, color) {
        ctx.fillStyle = color;
        ctx.font = '14px sans-serif';
        ctx.fillText(icon, x - 7, y + 3);
        ctx.fillStyle = 'white';
        ctx.font = '7px Inter';
        // 車両名をアイコンの上に配置
        const nameText = name.split(' ')[0];
        const textWidth = ctx.measureText(nameText).width;
        ctx.fillText(nameText, x - textWidth / 2, y - 18);
    }
    
