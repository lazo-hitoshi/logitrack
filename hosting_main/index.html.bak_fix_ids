<!DOCTYPE html> <html lang="ja"> <head> <meta charset="UTF-8"> <meta name="viewport" content="width=device-width, initial-scale=1.0"> <title>残土運搬運航監視システム - LogiTrack</title> <link rel="stylesheet" href="style.css?v=20260126-1911"> <link rel="preconnect" href="https://fonts.googleapis.com"> <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin> <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Outfit:wght@400;600;800&display=swap" rel="stylesheet"> </head> <body> <div class="app-container"> <aside class="sidebar"> <div class="logo"> <span class="logo-icon">⚓</span> <h1>LogiTrack</h1> </div> <nav class="nav-menu"> <a href="#" class="nav-item active" data-view="dashboard">ダッシュボード</a> <a href="#" class="nav-item" data-view="ship-tracking">船舶位置</a> <a href="#" class="nav-item" data-view="truck-tracking">ダンプ位置</a> <a href="#" class="nav-item" data-view="history">運搬履歴</a> <a href="#" class="nav-item" data-view="port-schedule">港入港スケジュール</a> <a href="#" class="nav-item" data-view="live-camera">ライブカメラ</a> </nav> <div class="system-status"> <p>システム稼働中</p> <div class="status-indicator"></div> </div> </aside> <main class="main-content"> <header class="top-bar"> <div class="search-bar"> <input type="search" placeholder="ロット番号・車両・船名で検索..."> </div> <div class="user-profile"> <span class="notification-icon">🔔</span> <div class="avatar">AD</div> </div> </header> <div id="dashboard-view" class="view"> <section class="kpi-grid"> <div class="kpi-card glass action-card"> <div class="actions"> <button id="open-modal-btn" class="glass-btn primary">＋ 新規ロット追加</button> <button id="open-truck-modal-btn" class="glass-btn secondary" onclick="window.openTruckEntryModal?.(); return false;">＋ 入場登録</button> </div> </div> <div class="kpi-card glass"> <h3>総積込量</h3> <div class="value">12,450 <span class="unit">t</span></div> <div class="trend positive">↑ 12% vs 昨日</div> </div> <div class="kpi-card glass"> <h3>船舶稼働数</h3> <div class="value">4 / 5</div> <div class="stat">稼働率 80%</div> </div> <div class="kpi-card glass"> <h3>ダンプ稼働数</h3> <div class="value">12 / 15</div> <div class="stat">稼働率 80%</div> </div> <div class="kpi-card glass"> <h3>最終埋立完了</h3> <div class="value">8,200 <span class="unit">t</span></div> <div class="progress-bar"> <div class="progress" style="width: 65%;"></div> </div> </div> </section> <section class="monitoring-map glass" id="tracking-map"> <div class="map-overlay"> <div class="map-header"> <div style="display: flex; align-items: center; gap: 20px;"> <h2 style="margin: 0;">リアルタイム監視マップ</h2> <div class="map-legend"> <span class="legend-item"><i class="port-marker"></i> 積込港</span> <span class="legend-item"><i class="ship-marker"></i> 船舶</span> <span class="legend-item"><i class="truck-marker"></i> ダンプ</span> <span class="legend-item"><i class="landfill-marker"></i> 最終埋立地</span> </div> </div> <div class="map-actions"> <button id="export-csv-btn" class="glass-btn secondary small">CSV出力</button> <button id="print-btn" class="glass-btn secondary small">印刷</button> </div> </div> </div> <div class="maps-container" style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; padding: 24px; margin-top: 20px;"> <div class="map-wrapper"> <h3 style="margin-bottom: 8px; color: var(--text-main); font-size: 0.75rem; font-weight: normal;">マップ 1</h3> <div id="map-canvas-1" class="map-canvas"> <!-- マップビジュアルは JS で描画予定 --> </div> </div> <div class="map-wrapper"> <h3 style="margin-bottom: 8px; color: var(--text-main); font-size: 0.75rem; font-weight: normal;">マップ 2</h3> <div id="map-canvas-2" class="map-canvas"> <!-- マップビジュアルは JS で描画予定 --> </div> </div> </div> </section> <div class="bottom-grid"> <section class="recent-alerts glass"> <h3>最近のアラート</h3> <div class="alert-list" id="alert-list"> <!-- JS で動的に生成 --> </div> </section> <section class="entry-registered glass"> <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;"> <h3 style="margin: 0;">入場登録済み（配車待ち）</h3> <button id="clear-entry-registered-btn" class="glass-btn secondary small" style="font-size: 0.75rem; padding: 4px 8px;" onclick="if(window.clearEntryRegistered) window.clearEntryRegistered(); else alert('クリア機能が読み込まれていません。ページをリロードしてください。');">クリア</button> </div> <div class="entry-registered-list" id="entry-registered-list-dashboard"> <!-- JS で動的に生成 --> </div> </section> </div> <div class="active-batches-section"> <section class="active-batches glass"> <h3>現在の運搬ロット（船）</h3> <div class="batch-table-container"> <table id="batch-table-sea"> <thead> <tr> <th>ロット管理番号</th> <th>船会社 / 船名</th> <th>輸送</th> <th>種別 / 書類</th> <th>最終埋立地</th> <th>現在地</th> <th>状況</th> <th>詳細</th> </tr> </thead> <tbody> <!-- JS で動的に生成 --> </tbody> </table> </div> </section> <section class="active-batches glass" style="margin-top: 20px;"> <h3>現在の運搬ロット（ダンプ）</h3> <div class="batch-table-container"> <table id="batch-table-land"> <thead> <tr> <th>ロット管理番号</th> <th>運送会社 / 車両</th> <th>元船</th> <th>輸送</th> <th>種別 / 書類</th> <th>最終埋立地</th> <th>現在地</th> <th>状況</th> <th>詳細</th> </tr> </thead> <tbody> <!-- JS で動的に生成 --> </tbody> </table> </div> </section> </div> </div> <!-- Ship Tracking View --> <div id="ship-tracking-view" class="view hidden"> <section class="glass"> <header class="section-header"> <h2>🚢 船舶稼働状況</h2> <div class="stat-badge">稼働中: <span id="ship-active-count">0</span>隻</div> </header> <div class="ship-grid" id="ship-grid"> <!-- JS Generated --> </div> </section> </div> <!-- Truck Tracking View --> <div id="truck-tracking-view" class="view hidden"> <!-- カンバンボード --> <section class="kanban-board"> <div class="kanban-column" id="col-standby" style="background: rgba(255, 255, 255, 0.03);"> <header> <span class="dot standby" style="background: var(--text-muted);"></span> <h3>入場済み / 待機</h3> <span class="count" id="count-standby">0</span> </header> <div class="kanban-list" id="list-standby"></div> </div> <div class="kanban-column" id="col-transport"> <header> <span class="dot transport"></span> <h3>輸送中（本日港通行予定）</h3> <span class="count" id="count-transport">0</span> </header> <div class="kanban-list" id="list-transport"></div> </div> </section> </div> <!-- History View --> <div id="history-view" class="view hidden"> <section class="glass"> <header class="section-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;"> <h3>運搬履歴一覧</h3> <div class="actions"> <input type="date" id="history-date-filter" class="glass-select"> <button id="history-export-csv-btn" class="glass-btn secondary small">CSV</button> <button id="history-print-btn" class="glass-btn secondary small">印刷</button> </div> </header> <div class="batch-table-container"> <table id="history-table"> <thead> <tr> <th>完了日時</th> <th>ロット番号</th> <th>船名 / 車両</th> <th>種別</th> <th>搬入先</th> <th>積載量</th> <th>状態</th> </tr> </thead> <tbody> <!-- JS Populated --> <tr> <td colspan="7" style="text-align: center; padding: 20px; color: var(--text-muted);">履歴データはありません </td> </tr> </tbody> </table> </div> </section> </div> <!-- Port Schedule View --> <div id="port-schedule-view" class="view hidden"> <section class="glass"> <header class="section-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;"> <h3>港入港スケジュール</h3> </header> <div id="port-schedule-calendar-wrap" class="batch-table-container" style="height: calc(100vh - 220px); min-height: 520px;"> <iframe id="port-schedule-calendar-frame" title="相馬港バース管理システム（カレンダー）" src="/soma-port/" style="width:100%; height:100%; border:0; border-radius: 12px;"></iframe> </div> </section> </div> <!-- Live Camera View --> <div id="live-camera-view" class="view hidden"> <section class="glass"> <header class="section-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;"> <div style="display:flex; flex-direction:column; gap:8px;"><h3>ライブカメラ</h3><div style="display:flex; gap:8px; margin:6px 0 10px;"><button id="tab-port" type="button" class="glass-btn secondary small" style="flex:0 0 auto;">港</button><button id="tab-landfill" type="button" class="glass-btn secondary small" style="flex:0 0 auto;">埋め立て現場</button></div></div> <div class="actions" style="display:flex; flex-direction:column; gap:8px; align-items:flex-end;">
  <div style="display:flex; gap:8px; align-items:center; width:min(900px, 100%);">
    <span class="glass-btn secondary small" style="pointer-events:none;">港</span>
    <input id="live-camera-url-port" type="url" class="glass-select" placeholder="港の配信URL（HLS .m3u8 / YouTube埋め込みURL）" style="flex:1; min-width: 260px;">
    <button id="live-camera-apply-btn-port" class="glass-btn primary small">表示</button>
  </div>
  <div style="display:flex; gap:8px; align-items:center; width:min(900px, 100%);">
    <span class="glass-btn secondary small" style="pointer-events:none;">埋め立て現場</span>
    <input id="live-camera-url-landfill" type="url" class="glass-select" placeholder="埋め立て現場の配信URL（HLS .m3u8 / YouTube埋め込みURL）" style="flex:1; min-width: 260px;">
    <button id="live-camera-apply-btn-landfill" class="glass-btn primary small">表示</button>
  </div>
  <div style="display:flex; gap:8px; justify-content:flex-end; width:min(900px, 100%);">
    <button id="live-camera-clear-btn" class="glass-btn secondary small">クリア</button><input id="live-camera-url" type="url" style="display:none;"><button id="live-camera-apply-btn" type="button" style="display:none;">表示</button><input id="live-camera-url" type="url" style="display:none;"><button id="live-camera-apply-btn" type="button" style="display:none;">表示</button><input id="live-camera-url" type="url" style="display:none;"><button id="live-camera-apply-btn" type="button" style="display:none;">表示</button><input id="live-camera-url" type="url" style="display:none;"><button id="live-camera-apply-btn" style="display:none;">表示</button>
  </div>
</div> </header> <div style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 10px; line-height: 1.6;"> ※ブラウザで安定して再生できるのは <b>HLS（.m3u8）</b> または <b>YouTube等の埋め込み</b> です。<br> ※RTSPのURLはブラウザで直接再生できないため、HLS/WebRTC等への変換が必要です。 </div> <div class="batch-table-container" style="height: 70vh;"> <div id="live-camera-empty" style="text-align:center; padding: 28px; color: var(--text-muted);"> 上のURLを入力して「表示」を押すとここに映像を表示します </div> <video id="live-camera-video" controls playsinline style="display:none; width:100%; height:100%; border-radius: 12px; background:#000;"></video> <iframe id="live-camera-iframe" title="ライブカメラ(埋め込み)" style="display:none; width:100%; height:100%; border:0; border-radius: 12px;"></iframe> </div> </section> </div> </main> </div> <div id="modal-overlay" class="modal-overlay hidden"> <div class="modal-content glass"> <header class="modal-header"> <div style="display:flex; align-items:center; gap:12px;"> <h2 id="lot-modal-title">新規ロット登録</h2> <button type="button" id="toggle-edit-mode-btn" class="glass-btn secondary small" style="display:none;">編集: OFF</button> </div> <button id="close-modal-btn" class="close-btn">&times;</button> </header> <form id="add-lot-form" class="entry-form"> <div class="form-grid-layout"> <!-- Left Column: Basic Info & Vehicle/Ship Info --> <div class="form-column"> <!-- 基本情報セクション --> <div class="form-section-divider" style="margin-bottom: 16px;"> <h3 style="font-size: 0.9rem; margin-bottom: 12px; color: var(--text-muted);">📋 基本情報</h3> </div> <div class="form-row"> <div class="form-group flex-grow" id="lot-id-group"> <label for="lot-id" id="label-lot-id">ロット番号（自動生成）</label> <input type="text" id="lot-id" readonly> <select id="parent-ship-select" style="display: none;"> <option value="">選択なし</option> </select> </div> <div class="form-group" style="width: 120px;" id="lot-type-row"> <label for="lot-type">種別</label> <select id="lot-type"> <option value="sea">船舶 🛳</option> <option value="land">ダンプ 🚛</option> </select> </div> </div> <div class="form-row" id="parent-ship-row" style="display: none;"></div> <!-- 船/車両情報セクション --> <div class="form-section-divider" style="margin-top: 20px; margin-bottom: 16px;"> <h3 style="font-size: 0.9rem; margin-bottom: 12px; color: var(--text-muted);" id="section-title-vehicle">🚢 船舶情報</h3> </div> <div class="form-group"> <label for="lot-company" id="label-company">船会社名</label> <div class="input-with-action"> <select id="lot-company"></select> <button type="button" class="add-master-btn" data-target="companies" title="新規追加">＋</button> </div> </div> <div class="form-group" id="ship-preset-row"> <label for="ship-preset-select">前回入力から選択（船）</label> <select id="ship-preset-select"> <option value="">選択なし</option> </select> </div> <div class="form-row"> <div class="form-group flex-grow"> <label for="lot-name" id="label-name">船名 / 車両番号</label> <div class="input-with-action"> <select id="lot-name"></select> <button type="button" class="add-master-btn" data-target="vessels" title="新規追加">＋</button> </div> </div> <div class="form-group" id="crew-field-group" style="width: 140px;"> <label for="lot-crew">船員人数</label> <input type="number" id="lot-crew" min="0" placeholder="0"> </div> </div> <!-- Land Specific --> <div id="land-specific-fields" style="display: none;"> <div class="form-row"> <div class="form-group flex-grow"> <label for="lot-driver">ドライバー名</label> <input type="text" id="lot-driver" placeholder="例：山田 太郎"> </div> <div class="form-group" style="width: 120px;"> <label for="lot-capacity">積載(m3)</label> <input type="text" id="lot-capacity" placeholder="10"> </div> </div> <div class="form-group"> <label for="lot-truck-category">車両区分</label> <div class="input-with-action"> <select id="lot-truck-category"></select> <button type="button" class="add-master-btn" data-target="truckCategories" title="車両区分を新規追加">＋</button> </div> </div> <div class="form-group"> <label>車両関連書類</label> <div class="file-upload-container"> <label for="lot-truck-docs" class="file-label glass"> <span class="icon">📎</span> <span id="lot-truck-docs-name" class="file-name">未選択</span> <input type="file" id="lot-truck-docs" class="hidden-input"> </label> </div> </div> </div> <!-- 備考 --> <div class="form-section-divider" style="margin-top: 20px; margin-bottom: 16px;"> <h3 style="font-size: 0.9rem; margin-bottom: 12px; color: var(--text-muted);">📝 備考</h3> </div> <div class="form-group"> <textarea id="lot-notes" placeholder="注意事項..." rows="4" style="width: 100%; padding: 10px; background: rgba(255, 255, 255, 0.05); border: 1px solid var(--glass-border); border-radius: 8px; color: var(--text-main); font-family: inherit; resize: vertical;"></textarea> </div> </div> <!-- Right Column: Operation & Material Info --> <div class="form-column"> <!-- 運行情報セクション --> <div class="form-section-divider" style="margin-bottom: 16px;"> <h3 style="font-size: 0.9rem; margin-bottom: 12px; color: var(--text-muted);">🚛 運行情報</h3> </div> <div class="form-row"> <div class="form-group flex-grow"> <label for="lot-location">現在地</label> <div class="input-with-action"> <select id="lot-location"></select> <button type="button" class="add-master-btn" data-target="ports" title="新規追加">＋</button> </div> </div> <div class="form-group flex-grow"> <label for="lot-site">最終埋立現場</label> <div class="input-with-action"> <select id="lot-site"></select> <button type="button" class="add-master-btn" data-target="sites" title="新規追加">＋</button> </div> </div> </div> <div class="form-row"> <div class="form-group flex-grow"> <label for="lot-status">状況</label> <select id="lot-status"> <option value="輸送中">輸送中</option> <option value="積込待ち">積込待ち</option> <option value="積込中">積込中</option> <option value="荷卸し中">荷卸し中</option> <option value="荷卸し完了">荷卸し完了</option> </select> </div> <div class="form-group flex-grow"> <label for="departure-date">出港予定日</label> <div class="input-with-action"> <input type="date" id="departure-date"> <button type="button" id="toggle-delay-btn" class="glass-btn secondary small" style="display: none;">遅延</button> </div> </div> </div> <!-- ダンプの場合のみ表示：配車予定日 --> <div class="form-group" id="dispatch-date-row" style="display: none;"> <label for="dispatch-date">配車予定日</label> <input type="date" id="dispatch-date"> </div> <!-- ダンプの場合のみ表示：港通行予定日 --> <div class="form-group" id="port-entry-date-row" style="display: none;"> <label for="port-entry-date">港通行予定日</label> <input type="date" id="port-entry-date"> </div> <!-- ダンプの場合のみ表示：荷元の船舶 --> <!-- 残土情報セクション --> <div class="form-section-divider" style="margin-top: 20px; margin-bottom: 16px;"> <h3 style="font-size: 0.9rem; margin-bottom: 12px; color: var(--text-muted);">🏗️ 残土情報</h3> </div> <div class="form-row"> <div class="form-group flex-grow"> <label for="soil-type">残土の種類</label> <select id="soil-type"> <option value="">選択してください</option> <option value="再生土">再生土</option> <option value="建設発生残土">建設発生残土</option> <option value="改良土">改良土</option> </select> </div> <div class="form-group flex-grow"> <label for="lot-plant">プラント会社名</label> <input type="text" id="lot-plant" placeholder="例：〇〇プラント"> </div> </div> <div class="form-row"> <div class="form-group" style="width: 140px;"> <label for="lot-gross-tonnage">総トン数</label> <input type="number" id="lot-gross-tonnage" min="0" step="0.01" placeholder="0.00"> </div> <div class="form-group" style="width: 140px;"> <label for="lot-weight-tonnage">重量トン数</label> <input type="number" id="lot-weight-tonnage" min="0" step="0.01" placeholder="0.00"> </div> <div class="form-group flex-grow"> <label for="lot-volume">数量ｍ³</label> <input type="number" id="lot-volume" min="0" step="0.01" placeholder="0.00"> </div> </div> <!-- 添付資料セクション --> <div class="form-section-divider" style="margin-top: 20px; margin-bottom: 16px;"> <h3 style="font-size: 0.9rem; margin-bottom: 12px; color: var(--text-muted);">📎 提出済み添付資料</h3> </div> <div class="form-group"> <div class="file-upload-group"> <div class="file-input-wrapper"> <label for="attach-analysis-file" class="file-label"> <span class="icon">📊</span> <span class="text">分析表</span> <span class="file-name" id="analysis-name">未選択</span> </label> <input type="file" id="attach-analysis-file" class="hidden-input"> </div> <div class="file-input-wrapper"> <label for="attach-cert-file" class="file-label"> <span class="icon">📜</span> <span class="text">発生証明</span> <span class="file-name" id="cert-name">未選択</span> </label> <input type="file" id="attach-cert-file" class="hidden-input"> </div> </div> </div> </div> <!-- Bottom Full Width: Map Settings & Actions --> <div class="full-width"> <div class="form-section-divider"> <h3 style="font-size: 0.9rem; margin-bottom: 12px; color: var(--text-muted);">⚓ マップ表示名設定（任意） </h3> <div class="form-row"> <div class="form-group"> <label for="loading-port-name">積込港名</label> <input type="text" id="loading-port-name" placeholder="積込港"> </div> <div class="form-group"> <label for="landing-port-name">荷降ろし港</label> <input type="text" id="landing-port-name" placeholder="荷降ろし港"> </div> </div> <div class="form-row" style="display:none;"> <input type="text" id="loading-port-pier"> <input type="text" id="landing-port-pier"> </div> </div> <div class="form-actions"> <button type="button" id="cancel-btn" class="secondary-btn">キャンセル</button> <button type="submit" class="primary-btn" id="submit-btn">登録する</button> <button type="button" id="move-to-standby-btn" class="secondary-btn" style="display: none; background-color: rgba(59, 130, 246, 0.2); color: var(--accent-blue);">待機に移動</button> <button type="button" id="delete-batch-btn" class="secondary-btn" style="display: none; background-color: rgba(239, 68, 68, 0.2); color: #ef4444;">削除</button> </div> </div> </form> </div> </div> <!-- ダンプマスタ登録モーダル --> <div id="truck-modal-overlay" class="modal-overlay hidden"> <div class="modal-content glass"> <header class="modal-header"> <h2>ダンプ入場登録 (待機)</h2> <button id="close-truck-modal-btn" class="close-btn">&times;</button> </header> <form id="add-truck-form" class="entry-form"> <div class="form-row"> <div class="form-group flex-grow"> <label for="truck-master-select">車両マスタから選択</label> <select id="truck-master-select"></select> </div> </div> <div class="form-row"> <div class="form-group flex-grow"> <label for="truck-name">車両ナンバー</label> <input type="text" id="truck-name" placeholder="例：品川 100 あ 1234" required> </div> <div class="form-group" style="width: 120px;"> <label for="truck-id">TruckID (自動生成)</label> <input type="text" id="truck-id" placeholder="自動" readonly> </div> </div> <div class="form-row"> <div class="form-group flex-grow"> <label for="truck-capacity">積載容量 (m3)</label> <input type="text" id="truck-capacity" placeholder="例：10" required> </div> </div> <div class="form-group"> <label for="truck-company-select">所属会社名</label> <div class="input-with-action"> <select id="truck-company-select"></select> <button type="button" class="add-master-btn" data-target="companies" title="会社を新規追加">＋</button> </div> </div> <div class="form-row"> <div class="form-group flex-grow"> <label for="truck-driver">ドライバー名</label> <input type="text" id="truck-driver" placeholder="例：山田 太郎" required> </div> <div class="form-group"> <label for="truck-category">車種</label> <div class="input-with-action"> <select id="truck-category"></select> <button type="button" class="add-master-btn" data-target="truckCategories" title="車両区分を新規追加">＋</button> </div> </div> </div> <div class="form-group"> <label>車両関連書類添付 (車検証など)</label> <div class="file-upload-container"> <label for="attach-truck-docs" class="file-label glass"> <span class="icon">📎</span> <span id="truck-docs-name" class="file-name">未選択</span> <input type="file" id="attach-truck-docs" class="hidden-input"> </label> </div> </div> <div class="form-actions"> <button type="button" id="cancel-truck-btn" class="secondary-btn">キャンセル</button> <button type="submit" class="primary-btn">入場登録する</button> </div> </form> </div> </div> <!-- Firebase (Firestore) --> <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-app-compat.js"></script> <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-firestore-compat.js"></script> <script> // Firebase Console → プロジェクトの設定 → SDK 設定と構成 から貼り付けてください // （※APIキーは秘匿情報ではありませんが、プロジェクトID等は正確に） window.firebaseConfig = window.firebaseConfig || { apiKey: "AIzaSyDDi3s1qJnNL_k8FtPPfAACCsCorj1XL1g", authDomain: "unkou-final.firebaseapp.com", projectId: "unkou-final", storageBucket: "unkou-final.firebasestorage.app", messagingSenderId: "841308334866", appId: "1:841308334866:web:dea92056a618686a5561cb" }; </script> <script src="app.js?v=20260127-0638"></script> </body>



















